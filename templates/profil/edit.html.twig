{% extends 'base.html.twig' %}
{% block title %}Mon profil{% endblock %}

{% block body %}
<div class="container py-5">
    <h1 class="fw-bold mb-4"><i class="bi bi-person-circle text-primary"></i> Mon profil</h1>

    <div class="row justify-content-center">
        <div class="col-md-7">
            <div class="card p-4">
                <div class="text-center mb-4">
                    {% if app.user.photoProfil %}
                        <img src="{{ asset('uploads/profils/' ~ app.user.photoProfil) }}" width="100" height="100" class="rounded-circle mb-2" style="object-fit:cover;" loading="lazy">
                    {% else %}
                        <div class="rounded-circle bg-primary d-inline-flex align-items-center justify-content-center mb-2" style="width:100px;height:100px;">
                            <span class="text-white fw-bold fs-3">{{ app.user.prenom|first|upper }}{{ app.user.nom|first|upper }}</span>
                        </div>
                    {% endif %}
                    <div class="fw-bold">{{ app.user.nomComplet }}</div>
                    <div class="text-muted small">{{ app.user.email }}</div>
                </div>

                {{ form_start(form, {attr: {enctype: 'multipart/form-data'}}) }}
                <div class="row g-3">
                    <div class="col-md-6">{{ form_label(form.prenom) }}{{ form_widget(form.prenom) }}{{ form_errors(form.prenom) }}</div>
                    <div class="col-md-6">{{ form_label(form.nom) }}{{ form_widget(form.nom) }}{{ form_errors(form.nom) }}</div>
                    <div class="col-12">{{ form_label(form.telephone) }}{{ form_widget(form.telephone) }}{{ form_errors(form.telephone) }}</div>
                    <div class="col-12">{{ form_label(form.photoFile) }}{{ form_widget(form.photoFile) }}{{ form_errors(form.photoFile) }}</div>
                </div>
                <div class="mt-4">
                    <button type="submit" class="btn btn-primary me-2">Enregistrer</button>
                    <a href="{{ path('app_home') }}" class="btn btn-outline-secondary">Annuler</a>
                </div>
                {{ form_end(form) }}
            </div>
        </div>

        {# Note moyenne #}
        <div class="col-md-7 mt-4">
            <div class="card p-4 mb-4">
                <h2 class="h5 fw-bold mb-3"><i class="bi bi-star-half text-warning"></i> Ma note</h2>
                {% if moyenne > 0 %}
                <div class="d-flex align-items-center gap-2">
                    {% for i in 1..5 %}
                        <i class="bi bi-star{{ i <= moyenne ? '-fill text-warning' : '' }} fs-5"></i>
                    {% endfor %}
                    <span class="fw-bold">{{ moyenne }}/5</span>
                    <span class="text-muted small">({{ evaluations|length }} avis)</span>
                </div>
                {% else %}
                <p class="text-muted small mb-0">Aucun avis reçu pour le moment.</p>
                {% endif %}
            </div>

            {% if isProprio and annonces|length > 0 %}
            <div class="card p-4 mb-4">
                <h2 class="h5 fw-bold mb-3"><i class="bi bi-megaphone text-info"></i> Mes annonces actives</h2>
                <div class="row g-3">
                    {% for annonce in annonces %}
                    {% if annonce.statut == 'disponible' %}
                    <div class="col-md-6">
                        <a href="{{ path('app_annonce_show', {id: annonce.id}) }}" class="text-decoration-none text-dark">
                            <div class="card h-100">
                                {% if annonce.premierPhoto %}
                                <img src="{{ asset('uploads/annonces/' ~ annonce.premierPhoto.filename) }}"
                                     class="card-img-top" style="height:100px;object-fit:cover;" loading="lazy">
                                {% endif %}
                                <div class="card-body p-2">
                                    <p class="fw-bold small mb-0">{{ annonce.titre }}</p>
                                    <p class="text-primary small mb-0">{{ annonce.prix }}€/mois</p>
                                </div>
                            </div>
                        </a>
                    </div>
                    {% endif %}
                    {% endfor %}
                </div>
            </div>
            {% endif %}

            {% if evaluations|length > 0 %}
            <div class="card p-4">
                <h2 class="h5 fw-bold mb-3"><i class="bi bi-chat-quote text-warning"></i>
                    {% if isProprio %}Avis de mes locataires{% else %}Avis de mes propriétaires{% endif %}
                </h2>
                {% for eval in evaluations %}
                <div class="border-bottom pb-3 mb-3">
                    <div class="d-flex align-items-center gap-2 mb-1">
                        {% for i in 1..5 %}
                            <i class="bi bi-star{{ i <= eval.note ? '-fill text-warning' : '' }}" style="font-size:14px;"></i>
                        {% endfor %}
                        <span class="fw-bold small">
                            {% if isProprio %}{{ eval.locataire.prenom }} {{ eval.locataire.nom|slice(0,1) }}.
                            {% else %}{{ eval.proprietaire.prenom }} {{ eval.proprietaire.nom|slice(0,1) }}.{% endif %}
                        </span>
                        <span class="text-muted small">{{ eval.creeLe|date('d/m/Y') }}</span>
                    </div>
                    {% if eval.commentaire %}<p class="mb-0 small">{{ eval.commentaire }}</p>{% endif %}
                </div>
                {% endfor %}
            </div>
            {% endif %}
        </div>
    </div>
</div>
{% endblock %}
