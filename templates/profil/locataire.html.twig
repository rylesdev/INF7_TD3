{% extends 'base.html.twig' %}
{% block title %}Profil de {{ locataire.nomComplet }}{% endblock %}

{% block body %}
<div class="container py-5">
    <div class="row g-4">
        <div class="col-md-4">
            <div class="card p-4 text-center">
                {% if locataire.photoProfil %}
                    <img src="{{ asset('uploads/profils/' ~ locataire.photoProfil) }}"
                         width="100" height="100" class="rounded-circle mx-auto d-block mb-3"
                         style="object-fit:cover;" loading="lazy">
                {% else %}
                    <div class="rounded-circle bg-secondary d-flex align-items-center justify-content-center mx-auto mb-3"
                         style="width:100px;height:100px;">
                        <i class="bi bi-person-fill text-white" style="font-size:2.5rem;"></i>
                    </div>
                {% endif %}
                <h1 class="h4 fw-bold mb-1">{{ locataire.prenom }} {{ locataire.nom|slice(0,1) }}.</h1>
                <p class="text-muted small mb-2"><i class="bi bi-person-home"></i> Locataire</p>
                {% if moyenne > 0 %}
                <div class="mb-2">
                    {% for i in 1..5 %}
                        <i class="bi bi-star{{ i <= moyenne ? '-fill text-warning' : '' }}"></i>
                    {% endfor %}
                    <span class="ms-1 small text-muted">{{ moyenne }}/5 ({{ evaluationsRecues|length }} avis)</span>
                </div>
                {% else %}
                <p class="text-muted small">Aucun avis pour le moment.</p>
                {% endif %}
            </div>
        </div>

        <div class="col-md-8">
            {% if evaluationsRecues|length > 0 %}
            <div class="card p-4 mb-4">
                <h2 class="h5 fw-bold mb-3"><i class="bi bi-chat-quote text-warning"></i> Avis des proprietaires</h2>
                {% for eval in evaluationsRecues %}
                <div class="border-bottom pb-3 mb-3">
                    <div class="d-flex align-items-center gap-2 mb-1">
                        <div>
                            {% for i in 1..5 %}
                                <i class="bi bi-star{{ i <= eval.note ? '-fill text-warning' : '' }}" style="font-size:14px;"></i>
                            {% endfor %}
                        </div>
                        <span class="fw-bold small">{{ eval.proprietaire.prenom }} {{ eval.proprietaire.nom|slice(0,1) }}.</span>
                        <span class="text-muted small">{{ eval.creeLe|date('d/m/Y') }}</span>
                        <span class="badge bg-light text-dark">{{ eval.colocation.nom }}</span>
                    </div>
                    {% if eval.commentaire %}
                        <p class="mb-0 small">{{ eval.commentaire }}</p>
                    {% endif %}
                </div>
                {% endfor %}
            </div>
            {% else %}
            <div class="card p-4 text-center text-muted">
                <i class="bi bi-person-check display-4 mb-2 d-block"></i>
                <p>Aucun avis de proprietaire pour le moment.</p>
            </div>
            {% endif %}
        </div>
    </div>
</div>
{% endblock %}
