{% extends 'base.html.twig' %}
{% block title %}Profil de {{ proprietaire.nomComplet }}{% endblock %}

{% block body %}
<div class="container py-5">
    <div class="row g-4">

        {# Colonne gauche : profil + évaluations #}
        <div class="col-md-4">

            <div class="card p-4 text-center mb-4">
                {% if proprietaire.photoProfil %}
                    <img src="{{ asset('uploads/profils/' ~ proprietaire.photoProfil) }}"
                         width="100" height="100" class="rounded-circle mx-auto d-block mb-3"
                         style="object-fit:cover;" loading="lazy">
                {% else %}
                    <div class="rounded-circle bg-primary d-flex align-items-center justify-content-center mx-auto mb-3"
                         style="width:100px;height:100px;">
                        <i class="bi bi-person-fill text-white" style="font-size:2.5rem;"></i>
                    </div>
                {% endif %}
                <h1 class="h4 fw-bold mb-1">{{ proprietaire.nomComplet }}</h1>
                <p class="text-muted small mb-2"><i class="bi bi-building"></i> Propriétaire</p>

                {% if moyenne > 0 %}
                <div class="mb-3">
                    {% for i in 1..5 %}
                        <i class="bi bi-star{{ i <= moyenne ? '-fill text-warning' : '' }}"></i>
                    {% endfor %}
                    <span class="ms-1 small text-muted">{{ moyenne }}/5 ({{ evaluations|length }} avis)</span>
                </div>
                {% else %}
                <p class="text-muted small mb-3">Aucun avis pour le moment.</p>
                {% endif %}

                {% if is_granted('ROLE_USER') and not is_granted('ROLE_PROPRIETAIRE') %}
                <a href="{{ path('app_locataire_evaluer_proprietaire', {id: proprietaire.id}) }}"
                   class="btn btn-outline-primary btn-sm">
                    <i class="bi bi-star"></i> Evaluer ce propriétaire
                </a>
                {% endif %}
            </div>

            {% if evaluations|length > 0 %}
            <div class="card p-4">
                <h2 class="h6 fw-bold mb-3"><i class="bi bi-chat-quote text-warning"></i> Avis des locataires</h2>
                {% for eval in evaluations %}
                <div class="{{ not loop.last ? 'border-bottom pb-3 mb-3' : '' }}">
                    <div class="d-flex align-items-center gap-2 mb-1">
                        {% for i in 1..5 %}<i class="bi bi-star{{ i <= eval.note ? '-fill text-warning' : '' }}" style="font-size:13px;"></i>{% endfor %}
                        <span class="fw-bold small">{{ eval.locataire.prenom }} {{ eval.locataire.nom|slice(0,1) }}.</span>
                        <span class="text-muted small ms-auto">{{ eval.creeLe|date('d/m/Y') }}</span>
                    </div>
                    {% if eval.commentaire %}
                        <p class="mb-0 small text-muted">{{ eval.commentaire }}</p>
                    {% endif %}
                </div>
                {% endfor %}
            </div>
            {% endif %}

        </div>

        {# Colonne droite : annonces actives #}
        <div class="col-md-8">
            <div class="card p-4">
                <h2 class="h5 fw-bold mb-4"><i class="bi bi-megaphone text-info"></i> Annonces actives</h2>
                {% set annoncesDisponibles = annonces|filter(a => a.statut == 'disponible') %}
                {% if annoncesDisponibles|length == 0 %}
                    <p class="text-muted">Aucune annonce active pour le moment.</p>
                {% else %}
                <div class="row g-3">
                    {% for annonce in annoncesDisponibles %}
                    <div class="col-sm-6">
                        <a href="{{ path('app_annonce_show', {id: annonce.id}) }}" class="text-decoration-none text-dark">
                            <div class="card h-100">
                                {% if annonce.premierPhoto %}
                                <img src="{{ asset('uploads/annonces/' ~ annonce.premierPhoto.filename) }}"
                                     class="card-img-top" style="height:140px;object-fit:cover;" loading="lazy"
                                     alt="{{ annonce.titre }}">
                                {% else %}
                                <div class="card-img-top bg-secondary d-flex align-items-center justify-content-center" style="height:140px;">
                                    <i class="bi bi-house text-white display-5"></i>
                                </div>
                                {% endif %}
                                <div class="card-body p-3">
                                    <p class="fw-bold small mb-1">{{ annonce.titre }}</p>
                                    <p class="text-primary small mb-1 fw-semibold">{{ annonce.prix }}€/mois</p>
                                    <p class="text-muted small mb-0"><i class="bi bi-geo-alt"></i> {{ annonce.localisation }}</p>
                                </div>
                            </div>
                        </a>
                    </div>
                    {% endfor %}
                </div>
                {% endif %}
            </div>
        </div>

    </div>
</div>
{% endblock %}
