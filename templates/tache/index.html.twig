{% extends 'base.html.twig' %}
{% block title %}{{ 'tasks.title'|trans }} — {{ colocation.nom }}{% endblock %}

{% block body %}
<div class="container py-5">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h1 class="fw-bold mb-0"><i class="bi bi-check2-circle text-primary"></i> {{ 'tasks.title'|trans }}</h1>
            <div class="text-muted small">{{ colocation.nom }}</div>
        </div>
        <a href="{{ path('app_tache_new', {colocationId: colocation.id}) }}" class="btn btn-primary">
            <i class="bi bi-plus-lg"></i> {{ 'forms.new_task'|trans }}
        </a>
    </div>

    {% if semainier is defined and semainier|length > 0 %}
    <div class="card p-4 mb-4">
        <h2 class="h5 fw-bold mb-3"><i class="bi bi-calendar-week text-info"></i> {{ 'tasks.weekly'|trans }}</h2>
        <div class="row g-2">
            {% set jours = {'Lundi': 'Lun', 'Mardi': 'Mar', 'Mercredi': 'Mer', 'Jeudi': 'Jeu', 'Vendredi': 'Ven', 'Samedi': 'Sam', 'Dimanche': 'Dim'} %}
            {% for jourNomComplet, jourNom in jours %}
            <div class="col">
                <div class="card p-2 text-center h-100 {{ 'now'|date('N') == loop.index ? 'border-primary' : '' }}">
                    <div class="fw-bold small mb-2 {{ 'now'|date('N') == loop.index ? 'text-primary' : 'text-muted' }}">{{ jourNom }}</div>
                    {% set tachesJour = semainier[jourNomComplet] ?? [] %}
                    {% for tache in tachesJour %}
                    <div class="badge bg-{{ tache.statut == 'terminee' ? 'success' : (tache.statut == 'en_cours' ? 'warning' : 'secondary') }} mb-1 text-wrap" style="font-size:.7rem;">
                        {{ tache.titre }}
                    </div>
                    {% else %}
                    <div class="text-muted" style="font-size:.75rem;">—</div>
                    {% endfor %}
                </div>
            </div>
            {% endfor %}
        </div>
    </div>
    {% endif %}

    {% set tachesActives   = taches|filter(t => t.statut != 'terminee') %}
    {% set tachesTerminees = taches|filter(t => t.statut == 'terminee') %}

    <h2 class="h5 fw-bold mb-3"><i class="bi bi-hourglass-split text-warning"></i> {{ 'tasks.active'|trans }}</h2>
    {% if tachesActives|length == 0 %}
        <div class="alert alert-success mb-4">
            <i class="bi bi-check-circle-fill"></i> {{ 'tasks.all_done'|trans }}
        </div>
    {% else %}
    <div class="card mb-4">
        <div class="table-responsive">
            <table class="table table-hover mb-0">
                <thead class="table-light">
                    <tr>
                        <th>{{ 'tasks.col_title'|trans }}</th>
                        <th>{{ 'tasks.col_type'|trans }}</th>
                        <th>{{ 'tasks.col_assigned'|trans }}</th>
                        <th>{{ 'tasks.col_date'|trans }}</th>
                        <th>{{ 'tasks.col_status'|trans }}</th>
                        <th>{{ 'tasks.col_actions'|trans }}</th>
                    </tr>
                </thead>
                <tbody>
                    {% for tache in tachesActives %}
                    <tr>
                        <td class="fw-bold">{{ tache.titre }}</td>
                        <td>{{ tache.libelleType }}</td>
                        <td>{{ tache.assigne ? tache.assigne.nomComplet : '—' }}</td>
                        <td>{{ tache.dateEcheance ? tache.dateEcheance|date('d/m/Y') : '—' }}</td>
                        <td>
                            <span class="badge bg-{{ tache.statut == 'en_cours' ? 'warning text-dark' : 'secondary' }}">
                                {{ tache.statut == 'en_cours' ? 'En cours' : 'À faire' }}
                            </span>
                        </td>
                        <td>
                            <div class="d-flex gap-1">
                                <form method="post" action="{{ path('app_tache_done', {id: tache.id}) }}">
                                    <input type="hidden" name="_token" value="{{ csrf_token('mark_done_' ~ tache.id) }}">
                                    <button type="submit" class="btn btn-sm btn-success">
                                        <i class="bi bi-check-lg"></i> {{ 'tasks.mark_done'|trans }}
                                    </button>
                                </form>
                                <form method="post" action="{{ path('app_tache_delete', {id: tache.id}) }}" onsubmit="return confirm('{{ 'tasks.delete_confirm'|trans }}')">
                                    <input type="hidden" name="_token" value="{{ csrf_token('delete_tache_' ~ tache.id) }}">
                                    <button type="submit" class="btn btn-sm btn-outline-danger"><i class="bi bi-trash"></i></button>
                                </form>
                            </div>
                        </td>
                    </tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>
    </div>
    {% endif %}

    {% if tachesTerminees|length > 0 %}
    <div class="mb-2">
        <button class="btn btn-sm btn-outline-secondary" type="button" data-bs-toggle="collapse" data-bs-target="#tachesTerminees">
            <i class="bi bi-check-all"></i> {{ 'tasks.done_section'|trans }} ({{ tachesTerminees|length }})
        </button>
    </div>
    <div class="collapse" id="tachesTerminees">
        <div class="card">
            <div class="table-responsive">
                <table class="table table-hover mb-0">
                    <thead class="table-light">
                        <tr>
                            <th>{{ 'tasks.col_title'|trans }}</th>
                            <th>{{ 'tasks.col_type'|trans }}</th>
                            <th>{{ 'tasks.col_assigned'|trans }}</th>
                            <th>{{ 'tasks.col_date'|trans }}</th>
                            <th></th>
                        </tr>
                    </thead>
                    <tbody>
                        {% for tache in tachesTerminees %}
                        <tr class="table-success opacity-75">
                            <td><s>{{ tache.titre }}</s></td>
                            <td>{{ tache.libelleType }}</td>
                            <td>{{ tache.assigne ? tache.assigne.nomComplet : '—' }}</td>
                            <td>{{ tache.dateEcheance ? tache.dateEcheance|date('d/m/Y') : '—' }}</td>
                            <td>
                                <form method="post" action="{{ path('app_tache_delete', {id: tache.id}) }}" onsubmit="return confirm('{{ 'tasks.delete_confirm'|trans }}')">
                                    <input type="hidden" name="_token" value="{{ csrf_token('delete_tache_' ~ tache.id) }}">
                                    <button type="submit" class="btn btn-sm btn-outline-danger"><i class="bi bi-trash"></i></button>
                                </form>
                            </td>
                        </tr>
                        {% endfor %}
                    </tbody>
                </table>
            </div>
        </div>
    </div>
    {% endif %}
</div>
{% endblock %}
