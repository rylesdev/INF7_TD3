{% extends 'base.html.twig' %}
{% block title %}{{ 'annonce.listings_title'|trans }}{% endblock %}
{% block meta_description %}Trouvez votre colocation idéale. {{ total }} annonces disponibles.{% endblock %}

{% block body %}
<div class="container py-5">
    <h1 class="fw-bold mb-4"><i class="bi bi-house-door text-primary"></i> {{ 'annonce.listings_title'|trans }}</h1>

    <form method="GET" action="{{ path('app_annonces') }}" class="card p-3 mb-4">
        <div class="row g-2 align-items-end">
            <div class="col-md-3">
                <label class="form-label small fw-bold">{{ 'annonce.filter_city'|trans }}</label>
                <select name="ville" class="form-select form-select-sm">
                    <option value="">{{ 'annonce.all_cities'|trans }}</option>
                    {% for ville in villes %}
                    <option value="{{ ville }}" {{ filters.ville == ville ? 'selected' : '' }}>{{ ville }}</option>
                    {% endfor %}
                </select>
            </div>
            <div class="col-md-2">
                <label class="form-label small fw-bold">{{ 'annonce.filter_price_min'|trans }} (€)</label>
                <input type="number" name="prix_min" class="form-control form-control-sm" placeholder="0" value="{{ filters.prix_min }}">
            </div>
            <div class="col-md-2">
                <label class="form-label small fw-bold">{{ 'annonce.filter_price_max'|trans }} (€)</label>
                <input type="number" name="prix_max" class="form-control form-control-sm" placeholder="2000" value="{{ filters.prix_max }}">
            </div>
            <div class="col-md-2">
                <button type="submit" class="btn btn-primary btn-sm w-100"><i class="bi bi-search"></i> {{ 'annonce.apply_filters'|trans }}</button>
            </div>
            {% if filters.ville or filters.prix_min or filters.prix_max %}
            <div class="col-md-2">
                <a href="{{ path('app_annonces') }}" class="btn btn-outline-secondary btn-sm w-100"><i class="bi bi-x"></i> {{ 'annonce.reset_filters'|trans }}</a>
            </div>
            {% endif %}
        </div>
    </form>

    <p class="text-muted small mb-3">{{ total }} annonce{{ total != 1 ? 's' : '' }} trouvée{{ total != 1 ? 's' : '' }}</p>

    {% if annonces|length == 0 %}
        <div class="alert alert-info">Aucune annonce ne correspond à vos critères.</div>
    {% else %}
        <div class="row g-4">
            {% for annonce in annonces %}
            <div class="col-md-4">
                <article class="card h-100">
                    {% if annonce.premierPhoto %}
                        <img src="{{ asset('uploads/annonces/' ~ annonce.premierPhoto.filename) }}"
                             class="card-img-top" alt="{{ annonce.premierPhoto.alt|default(annonce.titre) }}"
                             style="height:200px;object-fit:cover;" loading="lazy" width="400" height="200">
                    {% else %}
                        <div class="card-img-top bg-secondary d-flex align-items-center justify-content-center" style="height:200px;">
                            <i class="bi bi-house text-white display-3"></i>
                        </div>
                    {% endif %}
                    <div class="card-body">
                        <h2 class="h5 card-title">{{ annonce.titre }}</h2>
                        <p class="text-muted small mb-1"><i class="bi bi-geo-alt-fill text-danger"></i> {{ annonce.localisation }}</p>
                        <p class="fw-bold text-primary fs-5 mb-2">{{ annonce.prix }}€ <small class="fw-normal text-muted fs-6">/ mois</small></p>
                        <p class="card-text small text-muted">{{ annonce.description|slice(0, 100) }}{% if annonce.description|length > 100 %}…{% endif %}</p>
                    </div>
                    <div class="card-footer bg-transparent d-flex justify-content-between align-items-center">
                        <small class="text-muted"><i class="bi bi-eye"></i> {{ annonce.nbVisites }} vue(s)</small>
                        <a href="{{ path('app_annonce_show', {id: annonce.id}) }}" class="btn btn-primary btn-sm">
                            Voir le détail <i class="bi bi-arrow-right"></i>
                        </a>
                    </div>
                </article>
            </div>
            {% endfor %}
        </div>

        {% if totalPages > 1 %}
        <nav class="mt-4">
            <ul class="pagination justify-content-center">
                <li class="page-item {{ page == 1 ? 'disabled' : '' }}">
                    <a class="page-link" href="{{ path('app_annonces', filters|merge({page: page - 1})) }}">
                        <i class="bi bi-chevron-left"></i>
                    </a>
                </li>
                {% for p in 1..totalPages %}
                <li class="page-item {{ p == page ? 'active' : '' }}">
                    <a class="page-link" href="{{ path('app_annonces', filters|merge({page: p})) }}">{{ p }}</a>
                </li>
                {% endfor %}
                <li class="page-item {{ page == totalPages ? 'disabled' : '' }}">
                    <a class="page-link" href="{{ path('app_annonces', filters|merge({page: page + 1})) }}">
                        <i class="bi bi-chevron-right"></i>
                    </a>
                </li>
            </ul>
        </nav>
        {% endif %}
    {% endif %}
</div>
{% endblock %}
