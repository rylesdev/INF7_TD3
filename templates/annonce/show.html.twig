{% extends 'base.html.twig' %}
{% block title %}{{ annonce.titre }}{% endblock %}
{% block meta_description %}{{ annonce.metaDescription ?? annonce.description|slice(0,160) }}{% endblock %}
{% block og_title %}{{ annonce.titre }} – Colocation.com{% endblock %}
{% block og_description %}{{ annonce.metaDescription ?? annonce.description|slice(0,160) }}{% endblock %}

{% block body %}
<div class="container py-5">
    <nav aria-label="breadcrumb">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a href="{{ path('app_home') }}">Accueil</a></li>
            <li class="breadcrumb-item"><a href="{{ path('app_annonces') }}">Annonces</a></li>
            <li class="breadcrumb-item active">{{ annonce.titre }}</li>
        </ol>
    </nav>

    <div class="row g-4">
        <div class="col-lg-8">
            {# Galerie photos #}
            {% if annonce.photos|length > 0 %}
                <div id="photoCarousel" class="carousel slide mb-4" data-bs-ride="carousel">
                    <div class="carousel-inner rounded-3 overflow-hidden">
                        {% for i, photo in annonce.photos %}
                        <div class="carousel-item {{ i == 0 ? 'active' : '' }}">
                            <img src="{{ asset('uploads/annonces/' ~ photo.filename) }}"
                                 class="d-block w-100" alt="{{ photo.alt|default(annonce.titre) }}"
                                 style="height:400px;object-fit:cover;" loading="{{ i == 0 ? 'eager' : 'lazy' }}">
                        </div>
                        {% endfor %}
                    </div>
                    {% if annonce.photos|length > 1 %}
                        <button class="carousel-control-prev" type="button" data-bs-target="#photoCarousel" data-bs-slide="prev">
                            <span class="carousel-control-prev-icon"></span>
                        </button>
                        <button class="carousel-control-next" type="button" data-bs-target="#photoCarousel" data-bs-slide="next">
                            <span class="carousel-control-next-icon"></span>
                        </button>
                    {% endif %}
                </div>
            {% else %}
                <div class="bg-secondary rounded-3 d-flex align-items-center justify-content-center mb-4" style="height:300px;">
                    <i class="bi bi-house text-white display-1"></i>
                </div>
            {% endif %}

            <h1 class="fw-bold">{{ annonce.titre }}</h1>
            <p class="text-muted"><i class="bi bi-geo-alt-fill text-danger"></i> {{ annonce.localisation }}</p>

            <div class="card p-4 mb-4">
                <h2 class="h5 fw-bold mb-3">Description</h2>
                <p>{{ annonce.description|nl2br }}</p>
            </div>

            {# Avis #}
            <div class="card p-4 mb-4">
                <h2 class="h5 fw-bold mb-3">
                    <i class="bi bi-star-fill text-warning"></i> Avis
                    {% if annonce.moyenneNotes %}
                        <span class="fs-6 text-muted fw-normal ms-2">{{ annonce.moyenneNotes }}/5 ({{ avis|length }} avis)</span>
                    {% endif %}
                </h2>

                {% if avis|length == 0 %}
                    <p class="text-muted small">Aucun avis pour cette annonce.</p>
                {% else %}
                    {% for a in avis %}
                    <div class="border-bottom pb-3 mb-3">
                        <div class="d-flex align-items-center gap-2 mb-1">
                            <strong class="small">{{ a.auteur.prenom }} {{ a.auteur.nom|slice(0,1) }}.</strong>
                            <span class="text-warning small">
                                {% for i in 1..5 %}{{ i <= a.note ? '⭐' : '☆' }}{% endfor %}
                            </span>
                            <span class="text-muted small ms-auto">{{ a.creeLe|date('d/m/Y') }}</span>
                        </div>
                        {% if a.commentaire %}
                            <p class="small mb-0">{{ a.commentaire }}</p>
                        {% endif %}
                    </div>
                    {% endfor %}
                {% endif %}

                {% if avisForm is not null %}
                <div class="mt-3">
                    <h3 class="h6 fw-bold mb-3">Laisser un avis</h3>
                    {{ form_start(avisForm) }}
                    <div class="mb-3">
                        {{ form_label(avisForm.note) }}
                        <div class="star-rating-widget mt-1" id="avisStarWidget">
                            {% for choice in avisForm.note %}
                                {{ form_widget(choice, {attr: {class: 'star-radio'}}) }}
                                <label for="{{ choice.vars.id }}" class="star-label" title="{{ choice.vars.value }} étoile(s)">★</label>
                            {% endfor %}
                        </div>
                    </div>
                    <div class="mb-3">{{ form_row(avisForm.commentaire) }}</div>
                    <button type="submit" class="btn btn-primary btn-sm">Publier mon avis</button>
                    {{ form_end(avisForm) }}
                </div>
                {% elseif dejaAvis %}
                    <p class="text-muted small mt-2"><i class="bi bi-check-circle text-success"></i> Vous avez déjà laissé un avis pour cette annonce.</p>
                {% elseif is_granted('ROLE_USER') and not is_granted('ROLE_PROPRIETAIRE') and not peutNoter %}
                    <p class="text-muted small mt-2"><i class="bi bi-info-circle"></i> Vous pouvez noter cette colocation uniquement après avoir payé un loyer.</p>
                {% elseif not is_granted('ROLE_USER') %}
                    <a href="{{ path('app_login') }}" class="btn btn-outline-primary btn-sm mt-2">Se connecter pour laisser un avis</a>
                {% endif %}
            </div>

            {# Carte Leaflet.js #}
            {% if annonce.colocation.latitude and annonce.colocation.longitude %}
            <div class="card p-3 mb-4">
                <h2 class="h6 fw-bold mb-2"><i class="bi bi-map"></i> Localisation</h2>
                <div style="height:300px;border-radius:8px;overflow:hidden;">
                    <div id="map" style="height:100%;width:100%;"></div>
                </div>
            </div>
            {% endif %}
        </div>

        <div class="col-lg-4">
            <div class="card p-4 sticky-top" style="top:80px;">
                <div class="text-center mb-3">
                    <span class="display-6 fw-bold text-primary">{{ annonce.prix }}€</span>
                    <span class="text-muted"> / mois</span>
                </div>
                <hr>
                <ul class="list-unstyled">
                    <li class="mb-2">
                        <i class="bi bi-circle-fill text-{{ annonce.statut == 'disponible' ? 'success' : 'danger' }} me-2" style="font-size:.5rem;"></i>
                        {{ annonce.statut == 'disponible' ? 'Disponible' : 'Indisponible' }}
                    </li>
                    <li class="mb-2"><i class="bi bi-building me-2 text-muted"></i> {{ annonce.colocation.nom }}</li>
                    <li class="mb-2"><i class="bi bi-geo-alt me-2 text-muted"></i> {{ annonce.colocation.ville }} ({{ annonce.colocation.codePostal }})</li>
                    <li class="mb-2"><i class="bi bi-eye me-2 text-muted"></i> {{ annonce.nbVisites }} vue(s)</li>
                    <li class="mb-2"><i class="bi bi-calendar me-2 text-muted"></i> Publiée le {{ annonce.createdAt|date('d/m/Y') }}</li>
                </ul>
                {% if annonce.colocation.proprietaire %}
                <hr>
                <a href="{{ path('app_profil_proprietaire', {id: annonce.colocation.proprietaire.id}) }}"
                   class="d-flex align-items-center gap-3 text-decoration-none text-dark p-2 rounded hover-bg"
                   style="transition:background .15s;" onmouseover="this.style.background='#f8f9fa'" onmouseout="this.style.background=''">
                    {% if annonce.colocation.proprietaire.photoProfil %}
                        <img src="{{ asset('uploads/profils/' ~ annonce.colocation.proprietaire.photoProfil) }}"
                             class="rounded-circle" style="width:52px;height:52px;object-fit:cover;flex-shrink:0;" alt="Photo">
                    {% else %}
                        <div class="rounded-circle bg-primary d-flex align-items-center justify-content-center text-white fw-bold flex-shrink-0"
                             style="width:52px;height:52px;font-size:1.3rem;">
                            {{ annonce.colocation.proprietaire.prenom|slice(0,1)|upper }}
                        </div>
                    {% endif %}
                    <div class="flex-grow-1">
                        <div class="fw-bold">{{ annonce.colocation.proprietaire.prenom }} {{ annonce.colocation.proprietaire.nom }}</div>
                        <div class="small text-muted">Propriétaire</div>
                        {% if moyenneProprio > 0 %}
                        <div class="small">
                            {% for i in 1..5 %}<i class="bi bi-star{{ i <= moyenneProprio ? '-fill text-warning' : '' }}" style="font-size:11px;"></i>{% endfor %}
                            <span class="text-muted ms-1">{{ moyenneProprio }}/5 ({{ nbAvisProprio }} avis)</span>
                        </div>
                        {% else %}
                        <div class="small text-muted">Aucun avis</div>
                        {% endif %}
                    </div>
                    <i class="bi bi-chevron-right text-muted"></i>
                </a>
                {% endif %}
                <hr>
                {% if is_granted('ROLE_USER') and not is_granted('ROLE_PROPRIETAIRE') %}
                    {% if annonce.statut == 'disponible' %}
                        {% if dejaCandidat %}
                            <div class="alert alert-success py-2 text-center small mb-2">
                                <i class="bi bi-check-circle-fill"></i> Candidature envoyée, en attente de réponse
                            </div>
                        {% else %}
                            <a href="{{ path('app_locataire_candidature_form', {id: annonce.id}) }}"
                               class="btn btn-success w-100 mb-2">
                                <i class="bi bi-send"></i> Candidater
                            </a>
                        {% endif %}
                    {% endif %}
                    <a href="{{ path('app_locataire_messagerie_annonce', {id: annonce.id}) }}" class="btn btn-outline-primary w-100 mb-2">
                        <i class="bi bi-chat-dots"></i> Contacter le propriétaire
                    </a>
                {% elseif not is_granted('ROLE_USER') %}
                    <a href="{{ path('app_login') }}" class="btn btn-primary w-100 mb-2">
                        <i class="bi bi-box-arrow-in-right"></i> Se connecter pour candidater
                    </a>
                {% endif %}
                <a href="{{ path('app_annonces') }}" class="btn btn-outline-secondary w-100">
                    <i class="bi bi-arrow-left"></i> Retour aux annonces
                </a>
            </div>
        </div>
    </div>
</div>
{% endblock %}

{% block stylesheets %}
{% if annonce.colocation.latitude and annonce.colocation.longitude %}
<link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" crossorigin="">
{% endif %}
<style>
.star-rating-widget { display: flex; gap: 4px; }
.star-rating-widget .star-radio { display: none; }
.star-rating-widget .star-label { font-size: 2rem; color: #ddd; cursor: pointer; transition: color .1s; line-height: 1; }
.star-rating-widget .star-label.active { color: #ffc107; }
.star-rating-widget .star-label:hover { color: #ffc107; }
</style>
{% endblock %}

{% block javascripts %}
<script>
document.addEventListener('DOMContentLoaded', () => {
    const widget = document.getElementById('avisStarWidget');
    if (!widget) return;
    const inputs = widget.querySelectorAll('.star-radio');
    const labels = widget.querySelectorAll('.star-label');
    function highlight(n) { labels.forEach((l, i) => l.classList.toggle('active', i < n)); }
    inputs.forEach((inp, i) => {
        if (inp.checked) highlight(i + 1);
        inp.addEventListener('change', () => highlight(i + 1));
    });
    labels.forEach((lbl, i) => {
        lbl.addEventListener('mouseover', () => highlight(i + 1));
        lbl.addEventListener('mouseout', () => {
            const checked = [...inputs].findIndex(inp => inp.checked);
            highlight(checked >= 0 ? checked + 1 : 0);
        });
    });
});
</script>
{% if annonce.colocation.latitude and annonce.colocation.longitude %}
<script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js" crossorigin=""></script>
<script>
window.addEventListener('load', () => {
    const lat = {{ annonce.colocation.latitude }};
    const lng = {{ annonce.colocation.longitude }};
    const map = L.map('map').setView([lat, lng], 15);
    L.tileLayer('https://{s}.basemaps.cartocdn.com/rastertiles/voyager/{z}/{x}/{y}{r}.png', {
        attribution: '© <a href="https://www.openstreetmap.org/copyright">OpenStreetMap</a> © <a href="https://carto.com/">CARTO</a>',
        subdomains: 'abcd',
        maxZoom: 19
    }).addTo(map);
    L.marker([lat, lng])
        .addTo(map)
        .bindPopup('<b>{{ annonce.colocation.nom|escape('js') }}</b><br>{{ annonce.localisation|escape('js') }}')
        .openPopup();
    requestAnimationFrame(() => map.invalidateSize());
});
</script>
{% endif %}
{% endblock %}
