{% extends 'base.html.twig' %}
{% block title %}Modifier l'annonce{% endblock %}

{% block body %}
<div class="container py-5">
    <h1 class="fw-bold mb-4">Modifier l'annonce</h1>

    {% if sortedPhotos|length > 0 %}
    <div class="card p-4 mb-4">
        <p class="small fw-bold mb-2">Photos actuelles :</p>
        <div class="d-flex gap-2 flex-wrap mb-2">
            {% for photo in sortedPhotos %}
            <div class="position-relative">
                <img src="{{ asset('uploads/annonces/' ~ photo.filename) }}"
                     width="120" height="90"
                     style="object-fit:cover;border-radius:6px;border:2px solid #dee2e6;"
                     loading="lazy">
                <form method="POST"
                      action="{{ path('app_photo_delete', {photoId: photo.id}) }}"
                      onsubmit="return confirm('Supprimer cette photo ?')">
                    <input type="hidden" name="_token" value="{{ csrf_token('delete_photo_' ~ photo.id) }}">
                    <button type="submit"
                            class="btn btn-danger btn-sm position-absolute top-0 end-0"
                            style="padding:2px 6px;font-size:11px;border-radius:0 6px 0 6px;"
                            title="Supprimer">
                        <i class="bi bi-x"></i>
                    </button>
                </form>
            </div>
            {% endfor %}
        </div>
        <p class="text-muted small mb-0">{{ sortedPhotos|length }} photo(s). Minimum 1 requise.</p>
    </div>
    {% endif %}

    <div class="card p-4">
        {{ form_start(form, {attr: {enctype: 'multipart/form-data', novalidate: 'novalidate'}}) }}
            {{ form_errors(form) }}
            <div class="row g-3">
                <div class="col-md-8">{{ form_label(form.titre) }}{{ form_widget(form.titre) }}{{ form_errors(form.titre) }}</div>
                <div class="col-md-4">{{ form_label(form.prix) }}{{ form_widget(form.prix) }}{{ form_errors(form.prix) }}</div>
                <div class="col-12">{{ form_label(form.description) }}{{ form_widget(form.description) }}{{ form_errors(form.description) }}</div>
                <div class="col-md-6">{{ form_label(form.localisation) }}{{ form_widget(form.localisation) }}{{ form_errors(form.localisation) }}</div>
                <div class="col-md-3">{{ form_label(form.statut) }}{{ form_widget(form.statut) }}{{ form_errors(form.statut) }}</div>
                <div class="col-md-3">{{ form_label(form.colocation) }}{{ form_widget(form.colocation) }}{{ form_errors(form.colocation) }}</div>
                <div class="col-12">{{ form_label(form.metaDescription) }}{{ form_widget(form.metaDescription) }}{{ form_errors(form.metaDescription) }}</div>
                <div class="col-12">
                    {{ form_label(form.photoFiles, 'Ajouter des photos') }}
                    {{ form_widget(form.photoFiles) }}
                    {{ form_errors(form.photoFiles) }}
                </div>
            </div>
            <div class="mt-4">
                <button type="submit" class="btn btn-primary me-2">Enregistrer</button>
                <a href="{{ path('app_proprietaire_annonces') }}" class="btn btn-outline-secondary">Annuler</a>
            </div>
        {{ form_end(form) }}
    </div>
</div>
{% endblock %}
