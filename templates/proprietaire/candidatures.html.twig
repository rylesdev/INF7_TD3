{% extends 'base.html.twig' %}
{% block title %}{{ 'owner.candidatures.title'|trans }}{% endblock %}

{% block body %}
<div class="container py-5">
    <h1 class="fw-bold mb-4"><i class="bi bi-people text-primary"></i> {{ 'owner.candidatures.title'|trans }}</h1>

    {% if candidatures|length == 0 %}
        <div class="alert alert-info">
            <i class="bi bi-info-circle"></i> {{ 'owner.candidatures.no_applications'|trans }}
        </div>
    {% else %}
    <div class="card">
        <div class="table-responsive">
            <table class="table table-hover mb-0 align-middle">
                <thead class="table-light">
                    <tr>
                        <th>{{ 'owner.candidatures.col_applicant'|trans }}</th>
                        <th>{{ 'owner.candidatures.col_listing'|trans }}</th>
                        <th>{{ 'owner.candidatures.col_date'|trans }}</th>
                        <th>{{ 'owner.candidatures.col_status'|trans }}</th>
                        <th>{{ 'owner.candidatures.col_docs'|trans }}</th>
                        <th>{{ 'owner.candidatures.col_actions'|trans }}</th>
                    </tr>
                </thead>
                <tbody>
                    {% for c in candidatures %}
                    <tr>
                        <td>
                            <a href="{{ path('app_profil_locataire', {id: c.locataire.id}) }}" class="d-flex align-items-center gap-2 text-decoration-none text-dark">
                                {% if c.locataire.photoProfil %}
                                    <img src="{{ asset('uploads/profils/' ~ c.locataire.photoProfil) }}"
                                         class="rounded-circle" style="width:36px;height:36px;object-fit:cover;" alt="">
                                {% else %}
                                    <div class="rounded-circle bg-primary d-flex align-items-center justify-content-center text-white fw-bold"
                                         style="width:36px;height:36px;font-size:.9rem;">
                                        {{ c.locataire.prenom|slice(0,1)|upper }}
                                    </div>
                                {% endif %}
                                <div>
                                    <span class="fw-bold">{{ c.locataire.prenom }} {{ c.locataire.nom }}</span><br>
                                    <small class="text-muted">{{ c.locataire.email }}</small>
                                </div>
                            </a>
                        </td>
                        <td>
                            <a href="{{ path('app_annonce_show', {id: c.annonce.id}) }}" class="text-decoration-none">
                                {{ c.annonce.titre }}
                            </a><br>
                            <small class="text-muted">{{ c.annonce.colocation.nom }}</small>
                        </td>
                        <td>{{ c.creeLe|date('d/m/Y') }}</td>
                        <td>
                            {% if c.statut == 'en_attente' %}
                                <span class="badge bg-warning text-dark"><i class="bi bi-hourglass-split"></i> {{ 'owner.candidatures.status_pending'|trans }}</span>
                            {% elseif c.statut == 'accepte' %}
                                <span class="badge bg-success"><i class="bi bi-check-circle"></i> {{ 'owner.candidatures.status_accepted'|trans }}</span>
                            {% else %}
                                <span class="badge bg-danger"><i class="bi bi-x-circle"></i> {{ 'owner.candidatures.status_rejected'|trans }}</span>
                            {% endif %}
                        </td>
                        <td>
                            {% if c.pieceIdentite %}
                            <a href="{{ asset('uploads/candidatures/' ~ c.pieceIdentite) }}" target="_blank" class="btn btn-sm btn-outline-secondary me-1">
                                <i class="bi bi-card-heading"></i>
                            </a>
                            {% endif %}
                            {% if c.justificatifRevenu %}
                            <a href="{{ asset('uploads/candidatures/' ~ c.justificatifRevenu) }}" target="_blank" class="btn btn-sm btn-outline-secondary">
                                <i class="bi bi-file-earmark-text"></i>
                            </a>
                            {% endif %}
                            {% if not c.pieceIdentite and not c.justificatifRevenu %}
                            <span class="text-muted small">{{ 'owner.candidatures.no_docs'|trans }}</span>
                            {% endif %}
                        </td>
                        <td>
                            {% if c.statut == 'en_attente' %}
                            <div class="d-flex gap-2">
                                <a href="{{ path('app_proprietaire_candidature_accepter', {id: c.id}) }}"
                                   class="btn btn-sm btn-success">
                                    <i class="bi bi-check-lg"></i> {{ 'owner.candidatures.accept'|trans }}
                                </a>
                                <form method="POST" action="{{ path('app_proprietaire_candidature_refuser', {id: c.id}) }}"
                                      onsubmit="return confirm('{{ 'owner.candidatures.reject_confirm'|trans }}')">
                                    <input type="hidden" name="_token" value="{{ csrf_token('refuser_' ~ c.id) }}">
                                    <button type="submit" class="btn btn-sm btn-outline-danger">
                                        <i class="bi bi-x-lg"></i> {{ 'owner.candidatures.reject'|trans }}
                                    </button>
                                </form>
                            </div>
                            {% else %}
                                <span class="text-muted small">—</span>
                            {% endif %}
                        </td>
                    </tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>
    </div>
    {% endif %}
</div>
{% endblock %}
