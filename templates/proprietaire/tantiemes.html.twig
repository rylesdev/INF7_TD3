{% extends 'base.html.twig' %}
{% block title %}{{ 'tantiemes_prop.title'|trans }}{% endblock %}

{% block body %}
<div class="container py-5">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1 class="fw-bold mb-0"><i class="bi bi-pie-chart text-primary"></i> {{ 'tantiemes_prop.title'|trans }}</h1>
        <a href="{{ path('app_proprietaire_charges') }}" class="btn btn-outline-secondary btn-sm">
            <i class="bi bi-arrow-left"></i> {{ 'tantiemes_prop.back'|trans }}
        </a>
    </div>

    {% if grouped|length == 0 %}
        <div class="alert alert-info">
            <i class="bi bi-info-circle"></i>
            {{ 'tantiemes_prop.no_shares'|trans }}
            <a href="{{ path('app_proprietaire_charges') }}" class="alert-link ms-1">{{ 'tantiemes_prop.manage_charges'|trans }}</a>
        </div>
    {% else %}
        {% for colocationNom, charges in grouped %}
        <div class="mb-5">
            <h2 class="h5 fw-bold mb-3">
                <i class="bi bi-building text-secondary me-2"></i>{{ colocationNom }}
            </h2>

            {% for chargeId, data in charges %}
            {% set charge = data.charge %}
            <div class="card mb-3">
                <div class="card-header bg-light d-flex justify-content-between align-items-center">
                    <div>
                        <span class="fw-bold">{{ charge.description ?? charge.libelleType }}</span>
                        <span class="badge bg-secondary ms-2">{{ charge.libelleType }}</span>
                    </div>
                    <div class="text-end">
                        <span class="fw-bold text-primary fs-5">{{ charge.montant }}€</span>
                        <span class="text-muted small ms-1">total — {{ charge.date|date('d/m/Y') }}</span>
                    </div>
                </div>
                <div class="card-body p-0">
                    <div class="table-responsive">
                        <table class="table table-hover mb-0">
                            <thead class="table-light">
                                <tr>
                                    <th>{{ 'tantiemes_prop.col_room'|trans }}</th>
                                    <th>{{ 'tantiemes_prop.col_tenant'|trans }}</th>
                                    <th>{{ 'tantiemes_prop.col_surface'|trans }}</th>
                                    <th>{{ 'tantiemes_prop.col_share'|trans }}</th>
                                    <th class="text-end">{{ 'tantiemes_prop.col_amount'|trans }}</th>
                                </tr>
                            </thead>
                            <tbody>
                                {% set totalVerifie = 0 %}
                                {% for tantieme in data.tantiemes %}
                                {% set totalVerifie = totalVerifie + tantieme.montantDu %}
                                <tr>
                                    <td class="fw-bold">{{ tantieme.chambre.nom }}</td>
                                    <td>
                                        {% if tantieme.chambre.locataire %}
                                            <a href="{{ path('app_profil_locataire', {id: tantieme.chambre.locataire.id}) }}" class="text-decoration-none">
                                                {{ tantieme.chambre.locataire.nomComplet }}
                                            </a>
                                        {% else %}
                                            <span class="text-muted small">{{ 'tantiemes_prop.free_room'|trans }}</span>
                                        {% endif %}
                                    </td>
                                    <td>{{ tantieme.chambre.surface }} m²</td>
                                    <td>
                                        <div class="progress" style="height:18px;width:120px;">
                                            <div class="progress-bar bg-info" style="width:{{ tantieme.pourcentage }}%">
                                                {{ tantieme.pourcentage|number_format(1) }}%
                                            </div>
                                        </div>
                                    </td>
                                    <td class="text-end fw-bold text-primary">{{ tantieme.montantDu|number_format(2) }}€</td>
                                </tr>
                                {% endfor %}
                            </tbody>
                            <tfoot class="table-light">
                                <tr>
                                    <td colspan="4" class="fw-bold text-end">{{ 'tantiemes_prop.total'|trans }}</td>
                                    <td class="text-end fw-bold text-success">{{ totalVerifie|number_format(2) }}€</td>
                                </tr>
                            </tfoot>
                        </table>
                    </div>
                </div>
            </div>
            {% endfor %}
        </div>
        {% endfor %}
    {% endif %}
</div>
{% endblock %}
