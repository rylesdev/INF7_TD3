{% extends 'base.html.twig' %}
{% block title %}{{ 'owner.candidatures.accept'|trans }}{% endblock %}

{% block body %}
<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card p-4">
                <h1 class="h4 fw-bold mb-4"><i class="bi bi-check-circle text-success"></i> {{ 'owner.candidatures.accept'|trans }}</h1>

                <div class="d-flex align-items-center gap-3 mb-4 p-3 bg-light rounded">
                    {% if candidature.locataire.photoProfil %}
                        <img src="{{ asset('uploads/profils/' ~ candidature.locataire.photoProfil) }}"
                             class="rounded-circle" style="width:52px;height:52px;object-fit:cover;" alt="">
                    {% else %}
                        <div class="rounded-circle bg-primary d-flex align-items-center justify-content-center text-white fw-bold"
                             style="width:52px;height:52px;font-size:1.2rem;">
                            {{ candidature.locataire.prenom|slice(0,1)|upper }}
                        </div>
                    {% endif %}
                    <div>
                        <div class="fw-bold">{{ candidature.locataire.prenom }} {{ candidature.locataire.nom }}</div>
                        <div class="small text-muted">{{ candidature.annonce.titre }}</div>
                    </div>
                </div>

                <p class="text-muted small mb-3">{{ 'owner.candidatures.col_room'|trans }}</p>

                <form method="POST">
                    <input type="hidden" name="_token" value="{{ csrf_token('accepter_' ~ candidature.id) }}">
                    <div class="mb-4">
                        {% for chambre in chambresDisponibles %}
                        <div class="form-check border rounded p-3 mb-2">
                            <input class="form-check-input" type="radio" name="chambre_id"
                                   id="chambre_{{ chambre.id }}" value="{{ chambre.id }}" required>
                            <label class="form-check-label w-100" for="chambre_{{ chambre.id }}">
                                <span class="fw-bold">{{ chambre.nom }}</span>
                                <span class="text-muted ms-2">{{ chambre.surface }} m²</span>
                                <span class="badge bg-primary ms-2">{{ chambre.loyerMensuel }}€/mois</span>
                            </label>
                        </div>
                        {% endfor %}
                    </div>
                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-success flex-grow-1">
                            <i class="bi bi-check-lg"></i> {{ 'forms.confirm_acceptance'|trans }}
                        </button>
                        <a href="{{ path('app_proprietaire_candidatures') }}" class="btn btn-outline-secondary">
                            {{ 'forms.cancel'|trans }}
                        </a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>
{% endblock %}
