{% extends 'base.html.twig' %}
{% block title %}{{ 'owner.messagerie.title'|trans }}{% endblock %}

{% block body %}
<div class="container py-5">
    <h1 class="fw-bold mb-4"><i class="bi bi-chat-dots text-primary"></i> {{ 'owner.messagerie.title'|trans }}</h1>

    <div class="row g-4">
        <div class="col-md-4">
            <div class="card p-3">
                <h2 class="h6 fw-bold mb-3">{{ 'owner.messagerie.conversations'|trans }}</h2>
                {% if conversations|length == 0 %}
                    <p class="text-muted small">{{ 'owner.messagerie.no_conversations'|trans }}</p>
                {% else %}
                <div class="list-group list-group-flush">
                    {% for conv in conversations %}
                    <a href="{{ path('app_proprietaire_conversation', {colocationId: conv.colocation.id, locataireId: conv.user.id}) }}" class="list-group-item list-group-item-action px-2 py-2">
                        <div class="d-flex align-items-center gap-2">
                            {% if conv.user.photoProfil %}
                                <img src="{{ asset('uploads/profils/' ~ conv.user.photoProfil) }}" width="36" height="36" class="rounded-circle" style="object-fit:cover;" loading="lazy">
                            {% else %}
                                <div class="rounded-circle bg-secondary d-flex align-items-center justify-content-center" style="width:36px;height:36px;">
                                    <i class="bi bi-person-fill text-white"></i>
                                </div>
                            {% endif %}
                            <div class="flex-grow-1 overflow-hidden">
                                <div class="fw-bold small text-truncate">{{ conv.user.nomComplet }}</div>
                                <div class="text-muted small text-truncate">{{ conv.dernierMessage }}</div>
                            </div>
                            {% if conv.nonLus > 0 %}
                                <span class="badge bg-primary rounded-pill">{{ conv.nonLus }}</span>
                            {% endif %}
                        </div>
                    </a>
                    {% endfor %}
                </div>
                {% endif %}
            </div>
        </div>
        <div class="col-md-8">
            <div class="card p-5 text-center text-muted">
                <i class="bi bi-chat-left-text display-3 mb-3"></i>
                <p>{{ 'owner.messagerie.select_conv'|trans }}</p>
            </div>
        </div>
    </div>
</div>
{% endblock %}
