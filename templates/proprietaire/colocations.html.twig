{% extends 'base.html.twig' %}
{% block title %}Mes colocations{% endblock %}

{% block body %}
<div class="container py-5">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1 class="fw-bold mb-0"><i class="bi bi-building text-primary"></i> Mes colocations</h1>
        <a href="{{ path('app_proprietaire_colocation_new') }}" class="btn btn-primary">
            <i class="bi bi-plus-lg"></i> Nouvelle colocation
        </a>
    </div>

    {% if colocations|length == 0 %}
        <div class="alert alert-info">Vous n'avez pas encore de colocations.</div>
    {% else %}
    <div class="row g-4">
        {% for colocation in colocations %}
        <div class="col-md-6 col-lg-4">
            <div class="card h-100">
                <div class="card-body">
                    <h2 class="h5 fw-bold card-title">{{ colocation.nom }}</h2>
                    <p class="text-muted small mb-2"><i class="bi bi-geo-alt-fill text-danger"></i> {{ colocation.adresse }}, {{ colocation.ville }} {{ colocation.codePostal }}</p>
                    <p class="text-muted small mb-2"><i class="bi bi-house me-1"></i> {{ colocation.chambres|length }} chambre(s)</p>
                    <p class="fw-bold text-primary mb-2">{{ colocation.loyer }}€/mois</p>
                    {% if colocation.description %}
                    <p class="card-text small text-muted">{{ colocation.description|slice(0,100) }}{% if colocation.description|length > 100 %}…{% endif %}</p>
                    {% endif %}
                </div>
                <div class="card-footer bg-transparent d-flex gap-2">
                    <a href="{{ path('app_proprietaire_colocation_edit', {id: colocation.id}) }}" class="btn btn-sm btn-outline-primary flex-grow-1">
                        <i class="bi bi-pencil"></i> Modifier
                    </a>
                    <form method="post" action="{{ path('app_proprietaire_colocation_delete', {id: colocation.id}) }}" onsubmit="return confirm('Supprimer cette colocation ?')">
                        <input type="hidden" name="_token" value="{{ csrf_token('delete_colocation_' ~ colocation.id) }}">
                        <button type="submit" class="btn btn-sm btn-outline-danger">
                            <i class="bi bi-trash"></i>
                        </button>
                    </form>
                </div>
            </div>
        </div>
        {% endfor %}
    </div>
    {% endif %}
</div>
{% endblock %}
