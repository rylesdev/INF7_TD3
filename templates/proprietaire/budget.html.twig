{% extends 'base.html.twig' %}
{% block title %}{{ 'owner.budget.title'|trans }}{% endblock %}

{% block body %}
<div class="container py-5">

    <div class="d-flex justify-content-between align-items-center mb-4 flex-wrap gap-2">
        <h1 class="fw-bold mb-0"><i class="bi bi-bar-chart-line text-primary"></i> {{ 'owner.budget.title'|trans }}</h1>
        <form method="get" class="d-flex align-items-center gap-2">
            <label class="form-label mb-0 fw-semibold">{{ 'owner.budget.year'|trans }}</label>
            <select name="annee" class="form-select form-select-sm" onchange="this.form.submit()">
                {% for a in annees %}
                    <option value="{{ a }}" {% if a == annee %}selected{% endif %}>{{ a }}</option>
                {% endfor %}
            </select>
        </form>
    </div>

    {# KPIs #}
    <div class="row g-3 mb-4">
        <div class="col-6 col-md-3">
            <div class="card text-center p-3 border-success h-100">
                <div class="display-6 fw-bold text-success">{{ totalRecettes|number_format(2, ',', ' ') }} €</div>
                <div class="text-muted small mt-1">{{ 'owner.budget.receipts'|trans }}</div>
            </div>
        </div>
        <div class="col-6 col-md-3">
            <div class="card text-center p-3 border-danger h-100">
                <div class="display-6 fw-bold text-danger">{{ totalDepenses|number_format(2, ',', ' ') }} €</div>
                <div class="text-muted small mt-1">{{ 'owner.budget.expenses'|trans }}</div>
            </div>
        </div>
        <div class="col-6 col-md-3">
            <div class="card text-center p-3 border-{{ solde >= 0 ? 'primary' : 'warning' }} h-100">
                <div class="display-6 fw-bold text-{{ solde >= 0 ? 'primary' : 'warning' }}">{{ solde|number_format(2, ',', ' ') }} €</div>
                <div class="text-muted small mt-1">{{ 'owner.budget.balance'|trans }}</div>
            </div>
        </div>
        <div class="col-6 col-md-3">
            {% set impayes = loyersAttendus - totalRecettes %}
            <div class="card text-center p-3 border-{{ impayes > 0 ? 'warning' : 'secondary' }} h-100">
                <div class="display-6 fw-bold text-{{ impayes > 0 ? 'warning' : 'secondary' }}">{{ impayes|number_format(2, ',', ' ') }} €</div>
                <div class="text-muted small mt-1">{{ 'owner.budget.unpaid'|trans }}</div>
            </div>
        </div>
    </div>

    <div class="row g-4">

        {# Tableau mensuel #}
        <div class="col-lg-8">
            <div class="card">
                <div class="card-header fw-bold"><i class="bi bi-calendar3 me-2"></i>{{ 'owner.budget.monthly_table'|trans }}</div>
                <div class="table-responsive">
                    <table class="table table-hover mb-0">
                        <thead class="table-light">
                            <tr>
                                <th>{{ 'owner.budget.col_month'|trans }}</th>
                                <th class="text-end text-success">{{ 'owner.budget.col_receipts'|trans }}</th>
                                <th class="text-end text-danger">{{ 'owner.budget.col_expenses'|trans }}</th>
                                <th class="text-end">{{ 'owner.budget.col_balance'|trans }}</th>
                            </tr>
                        </thead>
                        <tbody>
                            {% for row in tableau %}
                            <tr>
                                <td class="fw-semibold">{{ row.nom }}</td>
                                <td class="text-end text-success">
                                    {% if row.recettes > 0 %}{{ row.recettes|number_format(2, ',', ' ') }} €{% else %}<span class="text-muted">-</span>{% endif %}
                                </td>
                                <td class="text-end text-danger">
                                    {% if row.depenses > 0 %}{{ row.depenses|number_format(2, ',', ' ') }} €{% else %}<span class="text-muted">-</span>{% endif %}
                                </td>
                                <td class="text-end fw-bold text-{{ row.solde > 0 ? 'success' : (row.solde < 0 ? 'danger' : 'muted') }}">
                                    {% if row.recettes > 0 or row.depenses > 0 %}
                                        {{ row.solde|number_format(2, ',', ' ') }} €
                                    {% else %}
                                        <span class="text-muted">-</span>
                                    {% endif %}
                                </td>
                            </tr>
                            {% endfor %}
                        </tbody>
                        <tfoot class="table-light fw-bold">
                            <tr>
                                <td>{{ 'owner.budget.total'|trans }}</td>
                                <td class="text-end text-success">{{ totalRecettes|number_format(2, ',', ' ') }} €</td>
                                <td class="text-end text-danger">{{ totalDepenses|number_format(2, ',', ' ') }} €</td>
                                <td class="text-end text-{{ solde >= 0 ? 'primary' : 'warning' }}">{{ solde|number_format(2, ',', ' ') }} €</td>
                            </tr>
                        </tfoot>
                    </table>
                </div>
            </div>
        </div>

        {# Répartition des charges par type #}
        <div class="col-lg-4">
            <div class="card h-100">
                <div class="card-header fw-bold"><i class="bi bi-pie-chart me-2"></i>{{ 'owner.budget.by_type'|trans }}</div>
                <div class="card-body">
                    {% if depensesParType is empty %}
                        <p class="text-muted">{{ 'owner.budget.no_expenses'|trans }}</p>
                    {% else %}
                        {% set typeLabels = {
                            'eau': 'Eau',
                            'electricite': 'Électricité',
                            'internet': 'Internet',
                            'taxes': 'Taxes',
                            'autre': 'Autre'
                        } %}
                        {% set typeIcons = {
                            'eau': 'bi-droplet text-info',
                            'electricite': 'bi-lightning text-warning',
                            'internet': 'bi-wifi text-primary',
                            'taxes': 'bi-bank text-secondary',
                            'autre': 'bi-three-dots text-dark'
                        } %}
                        {% for type, montant in depensesParType %}
                        <div class="mb-3">
                            <div class="d-flex justify-content-between align-items-center mb-1">
                                <span><i class="bi {{ typeIcons[type] ?? 'bi-circle' }} me-1"></i> {{ typeLabels[type] ?? type }}</span>
                                <span class="fw-bold">{{ montant|number_format(2, ',', ' ') }} €</span>
                            </div>
                            {% if totalDepenses > 0 %}
                            <div class="progress" style="height:6px">
                                <div class="progress-bar bg-danger" style="width: {{ ((montant / totalDepenses) * 100)|round }}%"></div>
                            </div>
                            {% endif %}
                        </div>
                        {% endfor %}
                        <hr>
                        <div class="d-flex justify-content-between fw-bold">
                            <span>{{ 'owner.budget.total'|trans }}</span>
                            <span class="text-danger">{{ totalDepenses|number_format(2, ',', ' ') }} €</span>
                        </div>
                    {% endif %}
                </div>
            </div>
        </div>

    </div>
</div>
{% endblock %}
