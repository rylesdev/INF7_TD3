{% extends 'base.html.twig' %}
{% block title %}Gestion des loyers{% endblock %}

{% block body %}
<div class="container py-5">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1 class="fw-bold mb-0"><i class="bi bi-cash-stack text-success"></i> Gestion des loyers</h1>
        <a href="{{ path('app_proprietaire_loyer_new') }}" class="btn btn-primary">
            <i class="bi bi-plus-lg"></i> Nouveau loyer
        </a>
    </div>

    {% if loyers|length == 0 %}
        <div class="alert alert-info">Aucun loyer enregistré.</div>
    {% else %}
    <div class="card">
        <div class="table-responsive">
            <table class="table table-hover mb-0">
                <thead class="table-light">
                    <tr>
                        <th>Colocation</th>
                        <th>Chambre</th>
                        <th>Période</th>
                        <th>Montant</th>
                        <th>Échéance</th>
                        <th>Statut</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    {% for loyer in loyers %}
                    <tr>
                        <td>{{ loyer.colocation.nom }}</td>
                        <td>{{ loyer.chambre ? loyer.chambre.nom : '—' }}</td>
                        <td>{{ loyer.mois }}/{{ loyer.annee }}</td>
                        <td class="fw-bold">{{ loyer.montant }}€</td>
                        <td>{{ loyer.dateEcheance|date('d/m/Y') }}</td>
                        <td>
                            <span class="badge bg-{{ loyer.statut == 'payé' ? 'success' : (loyer.statut == 'en_retard' ? 'danger' : 'warning') }}">
                                {{ loyer.statut }}
                            </span>
                        </td>
                        <td>
                            <div class="d-flex gap-1">
                                <a href="{{ path('app_proprietaire_loyer_edit', {id: loyer.id}) }}" class="btn btn-sm btn-outline-primary">
                                    <i class="bi bi-pencil"></i>
                                </a>
                                {% if loyer.statut == 'payé' and not loyer.quittance %}
                                <a href="{{ path('app_proprietaire_generer_quittance', {id: loyer.id}) }}" class="btn btn-sm btn-outline-danger">
                                    <i class="bi bi-file-earmark-pdf"></i>
                                </a>
                                {% endif %}
                                <form method="post" action="{{ path('app_proprietaire_loyer_delete', {id: loyer.id}) }}" onsubmit="return confirm('Supprimer ce loyer ?')">
                                    <input type="hidden" name="_token" value="{{ csrf_token('delete_loyer_' ~ loyer.id) }}">
                                    <button type="submit" class="btn btn-sm btn-outline-danger"><i class="bi bi-trash"></i></button>
                                </form>
                            </div>
                        </td>
                    </tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>
    </div>
    {% endif %}
</div>
{% endblock %}
