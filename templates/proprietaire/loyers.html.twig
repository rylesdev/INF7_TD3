{% extends 'base.html.twig' %}
{% block title %}{{ 'owner.loyers.title'|trans }}{% endblock %}

{% block body %}
<div class="container py-5">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1 class="fw-bold mb-0"><i class="bi bi-cash-stack text-success"></i> {{ 'owner.loyers.title'|trans }}</h1>
        <a href="{{ path('app_proprietaire_loyer_new') }}" class="btn btn-primary">
            <i class="bi bi-plus-lg"></i> {{ 'owner.loyers.new'|trans }}
        </a>
    </div>

    {% if loyers|length == 0 %}
        <div class="alert alert-info">{{ 'owner.loyers.no_rents'|trans }}</div>
    {% else %}
    <div class="card">
        <div class="table-responsive">
            <table class="table table-hover mb-0">
                <thead class="table-light">
                    <tr>
                        <th>{{ 'owner.loyers.col_colocation'|trans }}</th>
                        <th>{{ 'owner.loyers.col_room'|trans }}</th>
                        <th>{{ 'owner.loyers.col_tenant'|trans }}</th>
                        <th>{{ 'owner.loyers.col_period'|trans }}</th>
                        <th>{{ 'owner.loyers.col_amount'|trans }}</th>
                        <th>{{ 'owner.loyers.col_due_date'|trans }}</th>
                        <th>{{ 'owner.loyers.col_status'|trans }}</th>
                        <th>{{ 'owner.loyers.col_actions'|trans }}</th>
                    </tr>
                </thead>
                <tbody>
                    {% set statutLabels = {
                        'payé': 'owner.loyers.status_paid'|trans,
                        'impayé': 'owner.loyers.status_unpaid'|trans,
                        'en_retard': 'owner.loyers.status_overdue'|trans
                    } %}
                    {% for loyer in loyers %}
                    <tr>
                        <td>{{ loyer.colocation.nom }}</td>
                        <td>{{ loyer.chambre ? loyer.chambre.nom : '-' }}</td>
                        <td>
                            {% set loc = loyer.chambre ? loyer.chambre.locataire : null %}
                            {% if loc %}
                            <a href="{{ path('app_profil_locataire', {id: loc.id}) }}" class="text-decoration-none">
                                {{ loc.prenom }} {{ loc.nom|slice(0,1) }}.
                            </a>
                            {% else %}<span class="text-muted">-</span>{% endif %}
                        </td>
                        <td>{{ loyer.mois }}/{{ loyer.annee }}</td>
                        <td class="fw-bold">{{ loyer.montant }}€</td>
                        <td>{{ loyer.dateEcheance|date('d/m/Y') }}</td>
                        <td>
                            <span class="badge bg-{{ loyer.statut == 'payé' ? 'success' : (loyer.statut == 'en_retard' ? 'danger' : 'warning') }}">
                                {{ statutLabels[loyer.statut] ?? loyer.statut }}
                            </span>
                        </td>
                        <td>
                            <div class="d-flex gap-1 flex-wrap">
                                {% if loyer.statut != 'payé' %}
                                <form method="post" action="{{ path('app_proprietaire_loyer_payer', {id: loyer.id}) }}" onsubmit="return confirm('{{ 'owner.loyers.pay_confirm'|trans }}')">
                                    <input type="hidden" name="_token" value="{{ csrf_token('payer_loyer_proprio_' ~ loyer.id) }}">
                                    <button type="submit" class="btn btn-sm btn-success" title="{{ 'owner.loyers.pay_btn'|trans }}">
                                        <i class="bi bi-check-circle"></i> {{ 'owner.loyers.pay_btn'|trans }}
                                    </button>
                                </form>
                                {% endif %}
                                {% if loyer.statut == 'payé' and not loyer.quittance %}
                                <a href="{{ path('app_proprietaire_generer_quittance', {id: loyer.id}) }}" class="btn btn-sm btn-outline-danger" title="Générer quittance">
                                    <i class="bi bi-file-earmark-pdf"></i>
                                </a>
                                {% endif %}
                                <a href="{{ path('app_proprietaire_loyer_edit', {id: loyer.id}) }}" class="btn btn-sm btn-outline-primary">
                                    <i class="bi bi-pencil"></i>
                                </a>
                                <form method="post" action="{{ path('app_proprietaire_loyer_delete', {id: loyer.id}) }}" onsubmit="return confirm('{{ 'owner.loyers.delete_confirm'|trans }}')">
                                    <input type="hidden" name="_token" value="{{ csrf_token('delete_loyer_' ~ loyer.id) }}">
                                    <button type="submit" class="btn btn-sm btn-outline-danger"><i class="bi bi-trash"></i></button>
                                </form>
                            </div>
                        </td>
                    </tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>
    </div>
    {% endif %}
</div>
{% endblock %}
