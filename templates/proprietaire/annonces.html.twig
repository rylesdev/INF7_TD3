{% extends 'base.html.twig' %}
{% block title %}Mes annonces{% endblock %}

{% block body %}
<div class="container py-5">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1 class="fw-bold mb-0"><i class="bi bi-megaphone text-info"></i> Mes annonces</h1>
        <a href="{{ path('app_annonce_new') }}" class="btn btn-primary">
            <i class="bi bi-plus-lg"></i> Nouvelle annonce
        </a>
    </div>

    {% if annonces|length == 0 %}
        <div class="alert alert-info">Vous n'avez pas encore d'annonces.</div>
    {% else %}
    <div class="row g-4">
        {% for annonce in annonces %}
        <div class="col-md-6 col-lg-4">
            <div class="card h-100">
                {% if annonce.premierPhoto %}
                    <img src="{{ asset('uploads/annonces/' ~ annonce.premierPhoto.filename) }}"
                         class="card-img-top" alt="{{ annonce.titre }}"
                         style="height:160px;object-fit:cover;" loading="lazy">
                {% else %}
                    <div class="card-img-top bg-secondary d-flex align-items-center justify-content-center" style="height:160px;">
                        <i class="bi bi-house text-white display-4"></i>
                    </div>
                {% endif %}
                <div class="card-body">
                    <h2 class="h6 fw-bold card-title">{{ annonce.titre }}</h2>
                    <p class="text-muted small mb-1">{{ annonce.localisation }}</p>
                    <p class="fw-bold text-primary mb-1">{{ annonce.prix }}€/mois</p>
                    <span class="badge bg-{{ annonce.statut == 'disponible' ? 'success' : 'secondary' }}">{{ annonce.statut }}</span>
                </div>
                <div class="card-footer bg-transparent d-flex gap-2">
                    <a href="{{ path('app_annonce_show', {id: annonce.id}) }}" class="btn btn-sm btn-outline-info flex-grow-1">
                        <i class="bi bi-eye"></i>
                    </a>
                    <a href="{{ path('app_annonce_edit', {id: annonce.id}) }}" class="btn btn-sm btn-outline-primary flex-grow-1">
                        <i class="bi bi-pencil"></i>
                    </a>
                    <form method="post" action="{{ path('app_annonce_delete', {id: annonce.id}) }}" onsubmit="return confirm('Supprimer cette annonce ?')">
                        <input type="hidden" name="_token" value="{{ csrf_token('delete_annonce_' ~ annonce.id) }}">
                        <button type="submit" class="btn btn-sm btn-outline-danger"><i class="bi bi-trash"></i></button>
                    </form>
                </div>
            </div>
        </div>
        {% endfor %}
    </div>
    {% endif %}
</div>
{% endblock %}
