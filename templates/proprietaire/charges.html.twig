{% extends 'base.html.twig' %}
{% block title %}{{ 'owner.charges.title'|trans }}{% endblock %}

{% block body %}
<div class="container py-5">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1 class="fw-bold mb-0"><i class="bi bi-lightning text-warning"></i> {{ 'owner.charges.title'|trans }}</h1>
        <a href="{{ path('app_proprietaire_charge_new') }}" class="btn btn-primary">
            <i class="bi bi-plus-lg"></i> {{ 'owner.charges.new'|trans }}
        </a>
    </div>

    {% if charges|length == 0 %}
        <div class="alert alert-info">{{ 'owner.charges.no_charges'|trans }}</div>
    {% else %}
    <div class="card">
        <div class="table-responsive">
            <table class="table table-hover mb-0">
                <thead class="table-light">
                    <tr>
                        <th>{{ 'owner.charges.col_colocation'|trans }}</th>
                        <th>{{ 'owner.charges.col_type'|trans }}</th>
                        <th>{{ 'owner.charges.col_label'|trans }}</th>
                        <th>{{ 'owner.charges.col_amount'|trans }}</th>
                        <th>{{ 'owner.charges.col_date'|trans }}</th>
                        <th>{{ 'owner.charges.col_shares'|trans }}</th>
                        <th>{{ 'owner.charges.col_actions'|trans }}</th>
                    </tr>
                </thead>
                <tbody>
                    {% for charge in charges %}
                    <tr>
                        <td>{{ charge.colocation.nom }}</td>
                        <td>{{ charge.libelleType }}</td>
                        <td>{{ charge.description ?? '' }}</td>
                        <td class="fw-bold">{{ charge.montant }}€</td>
                        <td>{{ charge.date|date('d/m/Y') }}</td>
                        <td>
                            {% if charge.tantiemes|length > 0 %}
                                <span class="badge bg-success">{{ 'owner.charges.calculated'|trans }}</span>
                            {% else %}
                                <a href="{{ path('app_proprietaire_calculer_tantiemes', {id: charge.id}) }}" class="btn btn-sm btn-outline-warning">
                                    <i class="bi bi-calculator"></i> {{ 'owner.charges.calculate'|trans }}
                                </a>
                            {% endif %}
                        </td>
                        <td>
                            <div class="d-flex gap-1">
                                <a href="{{ path('app_proprietaire_charge_edit', {id: charge.id}) }}" class="btn btn-sm btn-outline-primary">
                                    <i class="bi bi-pencil"></i>
                                </a>
                                <form method="post" action="{{ path('app_proprietaire_charge_delete', {id: charge.id}) }}" onsubmit="return confirm('{{ 'owner.charges.delete_confirm'|trans }}')">
                                    <input type="hidden" name="_token" value="{{ csrf_token('delete_charge_' ~ charge.id) }}">
                                    <button type="submit" class="btn btn-sm btn-outline-danger"><i class="bi bi-trash"></i></button>
                                </form>
                            </div>
                        </td>
                    </tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>
    </div>
    {% endif %}
</div>
{% endblock %}
