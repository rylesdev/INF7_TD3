{% extends 'base.html.twig' %}
{% block title %}Gestion des charges{% endblock %}

{% block body %}
<div class="container py-5">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1 class="fw-bold mb-0"><i class="bi bi-lightning text-warning"></i> Gestion des charges</h1>
        <a href="{{ path('app_proprietaire_charge_new') }}" class="btn btn-primary">
            <i class="bi bi-plus-lg"></i> Nouvelle charge
        </a>
    </div>

    {% if charges|length == 0 %}
        <div class="alert alert-info">Aucune charge enregistrée.</div>
    {% else %}
    <div class="card">
        <div class="table-responsive">
            <table class="table table-hover mb-0">
                <thead class="table-light">
                    <tr>
                        <th>Colocation</th>
                        <th>Type</th>
                        <th>Libellé</th>
                        <th>Montant</th>
                        <th>Date</th>
                        <th>Tantièmes</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    {% for charge in charges %}
                    <tr>
                        <td>{{ charge.colocation.nom }}</td>
                        <td>{{ charge.libelleType }}</td>
                        <td>{{ charge.libelle }}</td>
                        <td class="fw-bold">{{ charge.montant }}€</td>
                        <td>{{ charge.date|date('d/m/Y') }}</td>
                        <td>
                            {% if charge.tantiemes|length > 0 %}
                                <span class="badge bg-success">Calculés</span>
                            {% else %}
                                <a href="{{ path('app_proprietaire_calculer_tantiemes', {id: charge.id}) }}" class="btn btn-sm btn-outline-warning">
                                    <i class="bi bi-calculator"></i> Calculer
                                </a>
                            {% endif %}
                        </td>
                        <td>
                            <div class="d-flex gap-1">
                                <a href="{{ path('app_proprietaire_charge_edit', {id: charge.id}) }}" class="btn btn-sm btn-outline-primary">
                                    <i class="bi bi-pencil"></i>
                                </a>
                                <form method="post" action="{{ path('app_proprietaire_charge_delete', {id: charge.id}) }}" onsubmit="return confirm('Supprimer cette charge ?')">
                                    <input type="hidden" name="_token" value="{{ csrf_token('delete_charge_' ~ charge.id) }}">
                                    <button type="submit" class="btn btn-sm btn-outline-danger"><i class="bi bi-trash"></i></button>
                                </form>
                            </div>
                        </td>
                    </tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>
    </div>
    {% endif %}
</div>
{% endblock %}
