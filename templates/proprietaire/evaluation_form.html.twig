{% extends 'base.html.twig' %}
{% block title %}{{ evaluation.id ? 'Modifier' : 'Évaluer' }} : {{ locataire.nomComplet }}{% endblock %}

{% block body %}
<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-md-7">
            <div class="d-flex align-items-center gap-3 mb-4">
                <a href="{{ path('app_proprietaire_evaluations') }}" class="btn btn-outline-secondary btn-sm">
                    <i class="bi bi-arrow-left"></i> Retour
                </a>
                <h1 class="h3 fw-bold mb-0">
                    <i class="bi bi-star-fill text-warning"></i>
                    {{ evaluation.id ? 'Modifier l\'évaluation' : 'Évaluer le locataire' }}
                </h1>
            </div>

            <div class="card mb-4">
                <div class="card-body d-flex align-items-center gap-3">
                    <div class="rounded-circle bg-primary d-flex align-items-center justify-content-center text-white fw-bold"
                         style="width:52px;height:52px;font-size:1.3rem">
                        {{ locataire.prenom|slice(0,1)|upper }}{{ locataire.nom|slice(0,1)|upper }}
                    </div>
                    <div>
                        <div class="fw-bold fs-5">{{ locataire.nomComplet }}</div>
                        <div class="text-muted small">
                            <i class="bi bi-building"></i> {{ colocation.nom }}, {{ colocation.ville }}
                        </div>
                    </div>
                </div>
            </div>

            <div class="card p-4">
                {{ form_start(form, {attr: {novalidate: 'novalidate'}}) }}

                <div class="mb-4">
                    <label class="form-label fw-bold">Note</label>
                    <div class="star-rating-widget" id="evalStarWidget">
                        {% for choice in form.note %}
                            {{ form_widget(choice, {attr: {class: 'star-radio'}}) }}
                            <label for="{{ choice.vars.id }}" class="star-label" title="{{ choice.vars.value }} étoile(s)">★</label>
                        {% endfor %}
                    </div>
                    {{ form_errors(form.note) }}
                </div>

                <div class="mb-4">
                    {{ form_row(form.commentaire) }}
                </div>

                <div class="d-flex gap-2">
                    <button type="submit" class="btn btn-primary">
                        <i class="bi bi-check-lg"></i>
                        {{ evaluation.id ? 'Mettre à jour' : 'Enregistrer l\'évaluation' }}
                    </button>
                    <a href="{{ path('app_proprietaire_evaluations') }}" class="btn btn-outline-secondary">Annuler</a>
                </div>

                {{ form_end(form) }}
            </div>
        </div>
    </div>
</div>
{% endblock %}

{% block stylesheets %}
<style>
.star-rating-widget { display: flex; gap: 4px; }
.star-rating-widget .star-radio { display: none; }
.star-rating-widget .star-label { font-size: 2rem; color: #ddd; cursor: pointer; transition: color .1s; line-height: 1; }
.star-rating-widget .star-label.active { color: #ffc107; }
.star-rating-widget .star-label:hover { color: #ffc107; }
</style>
{% endblock %}

{% block javascripts %}
<script>
document.addEventListener('DOMContentLoaded', () => {
    const widget = document.getElementById('evalStarWidget');
    if (!widget) return;
    const inputs = widget.querySelectorAll('.star-radio');
    const labels = widget.querySelectorAll('.star-label');
    function highlight(n) { labels.forEach((l, i) => l.classList.toggle('active', i < n)); }
    inputs.forEach((inp, i) => {
        if (inp.checked) highlight(i + 1);
        inp.addEventListener('change', () => highlight(i + 1));
    });
    labels.forEach((lbl, i) => {
        lbl.addEventListener('mouseover', () => highlight(i + 1));
        lbl.addEventListener('mouseout', () => {
            const checked = [...inputs].findIndex(inp => inp.checked);
            highlight(checked >= 0 ? checked + 1 : 0);
        });
    });
});
</script>
{% endblock %}
