{% extends 'base.html.twig' %}
{% block title %}{{ evaluation.id ? 'Modifier' : 'Évaluer' }} — {{ locataire.nomComplet }}{% endblock %}

{% block body %}
<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-md-7">
            <div class="d-flex align-items-center gap-3 mb-4">
                <a href="{{ path('app_proprietaire_evaluations') }}" class="btn btn-outline-secondary btn-sm">
                    <i class="bi bi-arrow-left"></i> Retour
                </a>
                <h1 class="h3 fw-bold mb-0">
                    <i class="bi bi-star-fill text-warning"></i>
                    {{ evaluation.id ? 'Modifier l\'évaluation' : 'Évaluer le locataire' }}
                </h1>
            </div>

            <div class="card mb-4">
                <div class="card-body d-flex align-items-center gap-3">
                    <div class="rounded-circle bg-primary d-flex align-items-center justify-content-center text-white fw-bold"
                         style="width:52px;height:52px;font-size:1.3rem">
                        {{ locataire.prenom[0]|upper }}{{ locataire.nom[0]|upper }}
                    </div>
                    <div>
                        <div class="fw-bold fs-5">{{ locataire.nomComplet }}</div>
                        <div class="text-muted small">
                            <i class="bi bi-building"></i> {{ colocation.nom }} — {{ colocation.ville }}
                        </div>
                    </div>
                </div>
            </div>

            <div class="card p-4">
                {{ form_start(form, {attr: {novalidate: 'novalidate'}}) }}

                <div class="mb-4">
                    <label class="form-label fw-bold">Note</label>
                    <div>
                        {% for choice in form.note %}
                        <div class="form-check form-check-inline">
                            {{ form_widget(choice) }}
                            {{ form_label(choice) }}
                        </div>
                        {% endfor %}
                    </div>
                    {{ form_errors(form.note) }}
                </div>

                <div class="mb-4">
                    {{ form_row(form.commentaire) }}
                </div>

                <div class="d-flex gap-2">
                    <button type="submit" class="btn btn-primary">
                        <i class="bi bi-check-lg"></i>
                        {{ evaluation.id ? 'Mettre à jour' : 'Enregistrer l\'évaluation' }}
                    </button>
                    <a href="{{ path('app_proprietaire_evaluations') }}" class="btn btn-outline-secondary">Annuler</a>
                </div>

                {{ form_end(form) }}
            </div>
        </div>
    </div>
</div>
{% endblock %}
