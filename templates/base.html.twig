<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta name="description" content="{% block meta_description %}Colocation.com – Gérez votre colocation simplement et efficacement.{% endblock %}">
    <meta name="robots" content="{% block meta_robots %}index, follow{% endblock %}">
    <link rel="canonical" href="{{ app.request.uri }}">
    <meta property="og:type" content="website">
    <meta property="og:title" content="{% block og_title %}Colocation.com{% endblock %}">
    <meta property="og:description" content="{% block og_description %}Gérez votre colocation simplement.{% endblock %}">
    <meta property="og:url" content="{{ app.request.uri }}">

    <title>{% block title %}Accueil{% endblock %} – Colocation.com</title>

    {# Bootstrap 5 CDN – CSS minifié avec cache HTTP (Green IT) #}
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css"
          integrity="sha384-QWTKZyjpPEjISv5WaRU9OFeRpok6YctnYmDr5pNlyT2bRjXh0JMhjY6hW+ALEwIH"
          crossorigin="anonymous">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">

    {% block stylesheets %}{% endblock %}

    <style>
        :root { --primary:#2c7be5; --secondary:#6e84a3; --success:#00d97e; --danger:#e63757; --warning:#f6c343; --dark:#12263f; --light:#f9fbfd; }
        body { background-color: var(--light); color: var(--dark); }
        .navbar-brand { font-weight:700; letter-spacing:1px; }
        .hero-section { background: linear-gradient(135deg, var(--primary), #1a4e90); color: white; padding: 80px 0; }
        .card { border:none; box-shadow:0 2px 12px rgba(0,0,0,.08); border-radius:12px; }
        .badge-notif { font-size:.65rem; }
    </style>
</head>
<body>

<nav class="navbar navbar-expand-lg navbar-dark" style="background-color: var(--dark);">
    <div class="container">
        <a class="navbar-brand" href="{{ path('app_home') }}"><i class="bi bi-house-heart-fill"></i> Colocation.com</a>
        <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navMain">
            <span class="navbar-toggler-icon"></span>
        </button>
        <div class="collapse navbar-collapse" id="navMain">
            <ul class="navbar-nav me-auto">
                <li class="nav-item"><a class="nav-link" href="{{ path('app_annonces') }}"><i class="bi bi-search"></i> Annonces</a></li>
                {% if is_granted('ROLE_USER') %}
                    {% if is_granted('ROLE_PROPRIETAIRE') %}
                        <li class="nav-item dropdown">
                            <a class="nav-link dropdown-toggle" href="#" data-bs-toggle="dropdown"><i class="bi bi-building"></i> Propriétaire</a>
                            <ul class="dropdown-menu">
                                <li><a class="dropdown-item" href="{{ path('app_proprietaire_dashboard') }}">Dashboard</a></li>
                                <li><a class="dropdown-item" href="{{ path('app_proprietaire_colocations') }}">Colocations</a></li>
                                <li><a class="dropdown-item" href="{{ path('app_proprietaire_annonces') }}">Annonces</a></li>
                                <li><a class="dropdown-item" href="{{ path('app_proprietaire_loyers') }}">Loyers</a></li>
                                <li><a class="dropdown-item" href="{{ path('app_proprietaire_charges') }}">Charges</a></li>
                                <li><a class="dropdown-item" href="{{ path('app_proprietaire_messagerie') }}">Messagerie</a></li>
                            </ul>
                        </li>
                    {% else %}
                        <li class="nav-item dropdown">
                            <a class="nav-link dropdown-toggle" href="#" data-bs-toggle="dropdown"><i class="bi bi-person-home"></i> Locataire</a>
                            <ul class="dropdown-menu">
                                <li><a class="dropdown-item" href="{{ path('app_locataire_dashboard') }}">Dashboard</a></li>
                                <li><a class="dropdown-item" href="{{ path('app_locataire_loyers') }}">Mes loyers</a></li>
                                <li><a class="dropdown-item" href="{{ path('app_locataire_quittances') }}">Quittances</a></li>
                                <li><a class="dropdown-item" href="{{ path('app_locataire_tantiemes') }}">Tantièmes</a></li>
                                <li><a class="dropdown-item" href="{{ path('app_locataire_messagerie') }}">Messagerie</a></li>
                            </ul>
                        </li>
                    {% endif %}
                {% endif %}
            </ul>
            <ul class="navbar-nav ms-auto align-items-center">
                {% if is_granted('ROLE_USER') %}
                    <li class="nav-item me-2">
                        <a class="nav-link position-relative" href="{{ path('app_locataire_notifications') }}">
                            <i class="bi bi-bell-fill"></i>
                            <span class="position-absolute top-0 start-100 translate-middle badge rounded-pill bg-danger badge-notif" id="notifCount" style="display:none">0</span>
                        </a>
                    </li>
                    <li class="nav-item dropdown">
                        <a class="nav-link dropdown-toggle" href="#" data-bs-toggle="dropdown">
                            {% if app.user.photoProfil %}
                                <img src="{{ asset('uploads/profils/' ~ app.user.photoProfil) }}" alt="Profil" width="28" height="28" class="rounded-circle me-1" loading="lazy">
                            {% else %}
                                <i class="bi bi-person-circle"></i>
                            {% endif %}
                            {{ app.user.prenom }}
                        </a>
                        <ul class="dropdown-menu dropdown-menu-end">
                            <li><a class="dropdown-item" href="{{ path('app_profil') }}"><i class="bi bi-person-gear"></i> Mon profil</a></li>
                            <li><hr class="dropdown-divider"></li>
                            <li><a class="dropdown-item" href="{{ path('app_logout') }}"><i class="bi bi-box-arrow-right"></i> Déconnexion</a></li>
                        </ul>
                    </li>
                {% else %}
                    <li class="nav-item"><a class="nav-link" href="{{ path('app_login') }}"><i class="bi bi-box-arrow-in-right"></i> Connexion</a></li>
                    <li class="nav-item"><a class="btn btn-primary btn-sm ms-2" href="{{ path('app_register') }}">S'inscrire</a></li>
                {% endif %}
            </ul>
        </div>
    </div>
</nav>

<div class="container mt-3">
    {% for type, messages in app.flashes %}
        {% for message in messages %}
            <div class="alert alert-{{ type == 'error' ? 'danger' : type }} alert-dismissible fade show" role="alert">
                {{ message }}<button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
        {% endfor %}
    {% endfor %}
</div>

{% block body %}{% endblock %}

<footer class="mt-5 py-4" style="background-color: var(--dark); color: #adb5bd;">
    <div class="container text-center">
        <p class="mb-1">&copy; {{ 'now'|date('Y') }} Colocation.com</p>
        <small>
            <a href="{{ path('app_annonces') }}" class="text-secondary me-3">Annonces</a>
            <a href="{{ path('app_home') }}#faq" class="text-secondary me-3">FAQ</a>
            <a href="{{ path('app_sitemap') }}" class="text-secondary">Sitemap</a>
        </small>
    </div>
</footer>

{# Bootstrap JS différé – Green IT #}
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"
        crossorigin="anonymous" defer></script>

{% if is_granted('ROLE_USER') %}
<script defer>
document.addEventListener('DOMContentLoaded', () => {
    fetch('{{ path('app_notifications_count') }}')
        .then(r => r.json())
        .then(data => {
            if (data.count > 0) {
                const b = document.getElementById('notifCount');
                if (b) { b.textContent = data.count; b.style.display = ''; }
            }
        }).catch(() => {});
});
</script>
{% endif %}

{% block javascripts %}{% endblock %}
</body>
</html>
