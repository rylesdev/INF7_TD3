<!DOCTYPE html>
<html lang="{{ app.request.locale }}">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta name="description" content="{% block meta_description %}Colocation.com – Gérez votre colocation simplement et efficacement.{% endblock %}">
    <meta name="robots" content="{% block meta_robots %}index, follow{% endblock %}">
    <link rel="canonical" href="{{ app.request.uri }}">
    <meta property="og:type" content="website">
    <meta property="og:title" content="{% block og_title %}Colocation.com{% endblock %}">
    <meta property="og:description" content="{% block og_description %}Gérez votre colocation simplement.{% endblock %}">
    <meta property="og:url" content="{{ app.request.uri }}">

    <title>{% block title %}{{ 'nav.home'|trans }}{% endblock %} – {{ 'app.name'|trans }}</title>

    {# Bootstrap 5 CDN – CSS minifié avec cache HTTP (Green IT) #}
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css"
          integrity="sha384-QWTKZyjpPEjISv5WaRU9OFeRpok6YctnYmDr5pNlyT2bRjXh0JMhjY6hW+ALEwIH"
          crossorigin="anonymous">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">

    {% block stylesheets %}{% endblock %}

    <style>
        :root { --primary:#2c7be5; --secondary:#6e84a3; --success:#00d97e; --danger:#e63757; --warning:#f6c343; --dark:#12263f; --light:#f9fbfd; }
        body { background-color: var(--light); color: var(--dark); }
        .navbar-brand { font-weight:700; letter-spacing:1px; }
        .hero-section { background: linear-gradient(135deg, var(--primary), #1a4e90); color: white; padding: 80px 0; }
        .card { border:none; box-shadow:0 2px 12px rgba(0,0,0,.08); border-radius:12px; }
        .badge-notif { font-size:.65rem; }
    </style>
</head>
<body>

<nav class="navbar navbar-expand-lg navbar-dark" style="background-color: var(--dark);">
    <div class="container">
        <a class="navbar-brand" href="{{ path('app_home') }}"><i class="bi bi-house-heart-fill"></i> {{ 'app.name'|trans }}</a>
        <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navMain">
            <span class="navbar-toggler-icon"></span>
        </button>
        <div class="collapse navbar-collapse" id="navMain">
            <ul class="navbar-nav me-auto">
                <li class="nav-item"><a class="nav-link" href="{{ path('app_annonces') }}"><i class="bi bi-search"></i> {{ 'nav.annonces'|trans }}</a></li>
                {% if is_granted('ROLE_PROPRIETAIRE') %}
                    <li class="nav-item">
                        <a class="nav-link" href="{{ path('app_proprietaire_dashboard') }}"><i class="bi bi-speedometer2"></i> {{ 'nav.dashboard'|trans }}</a>
                    </li>
                    <li class="nav-item dropdown">
                        <a class="nav-link dropdown-toggle" href="#" data-bs-toggle="dropdown"><i class="bi bi-building"></i> {{ 'nav.management'|trans }}</a>
                        <ul class="dropdown-menu">
                            <li><a class="dropdown-item" href="{{ path('app_proprietaire_colocations') }}"><i class="bi bi-house-door me-2"></i>{{ 'nav.colocations'|trans }}</a></li>
                            <li><a class="dropdown-item" href="{{ path('app_proprietaire_annonces') }}"><i class="bi bi-megaphone me-2"></i>{{ 'nav.listings'|trans }}</a></li>
                            <li><a class="dropdown-item" href="{{ path('app_proprietaire_candidatures') }}"><i class="bi bi-people me-2"></i>{{ 'nav.applications'|trans }}</a></li>
                        </ul>
                    </li>
                    <li class="nav-item dropdown">
                        <a class="nav-link dropdown-toggle" href="#" data-bs-toggle="dropdown"><i class="bi bi-cash-stack"></i> {{ 'nav.finances'|trans }}</a>
                        <ul class="dropdown-menu">
                            <li><a class="dropdown-item" href="{{ path('app_proprietaire_loyers') }}"><i class="bi bi-calendar-check me-2"></i>{{ 'nav.rents'|trans }}</a></li>
                            <li><a class="dropdown-item" href="{{ path('app_proprietaire_charges') }}"><i class="bi bi-receipt me-2"></i>{{ 'nav.charges'|trans }}</a></li>
                            <li><a class="dropdown-item" href="{{ path('app_proprietaire_tantiemes') }}"><i class="bi bi-pie-chart me-2"></i>{{ 'nav.shares'|trans }}</a></li>
                        </ul>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" href="{{ path('app_proprietaire_messagerie') }}">
                            <i class="bi bi-chat-dots"></i> {{ 'nav.messaging'|trans }}
                            <span class="badge bg-danger ms-1" id="msgBadge" style="display:none">0</span>
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" href="{{ path('app_proprietaire_evaluations') }}"><i class="bi bi-star"></i> {{ 'nav.evaluations'|trans }}</a>
                    </li>
                {% elseif is_granted('ROLE_USER') %}
                    <li class="nav-item">
                        <a class="nav-link" href="{{ path('app_locataire_dashboard') }}"><i class="bi bi-speedometer2"></i> {{ 'nav.dashboard'|trans }}</a>
                    </li>
                    <li class="nav-item dropdown">
                        <a class="nav-link dropdown-toggle" href="#" data-bs-toggle="dropdown"><i class="bi bi-house-door"></i> {{ 'nav.my_apartment'|trans }}</a>
                        <ul class="dropdown-menu">
                            <li><a class="dropdown-item" href="{{ path('app_locataire_loyers') }}"><i class="bi bi-calendar-check me-2"></i>{{ 'nav.rents'|trans }}</a></li>
                            <li><a class="dropdown-item" href="{{ path('app_locataire_quittances') }}"><i class="bi bi-file-earmark-pdf me-2"></i>{{ 'nav.receipts'|trans }}</a></li>
                            <li><a class="dropdown-item" href="{{ path('app_locataire_tantiemes') }}"><i class="bi bi-pie-chart me-2"></i>{{ 'nav.shares'|trans }}</a></li>
                            {% if app.user.chambres|length > 0 %}
                            <li><a class="dropdown-item" href="{{ path('app_taches', {colocationId: app.user.chambres|first.colocation.id}) }}"><i class="bi bi-check2-circle me-2"></i>{{ 'nav.tasks'|trans }}</a></li>
                            {% endif %}
                        </ul>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" href="{{ path('app_locataire_candidatures') }}"><i class="bi bi-send"></i> {{ 'nav.candidatures'|trans }}</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" href="{{ path('app_locataire_messagerie') }}">
                            <i class="bi bi-chat-dots"></i> {{ 'nav.messaging'|trans }}
                            <span class="badge bg-danger ms-1" id="msgBadge" style="display:none">0</span>
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" href="{{ path('app_locataire_evaluations') }}"><i class="bi bi-star"></i> {{ 'nav.evaluations'|trans }}</a>
                    </li>
                {% endif %}
            </ul>
            <ul class="navbar-nav ms-auto align-items-center">
                {# Sélecteur de langue #}
                <li class="nav-item dropdown me-2">
                    <a class="nav-link dropdown-toggle" href="#" data-bs-toggle="dropdown">
                        <i class="bi bi-globe2"></i>
                        {{ app.request.locale == 'en' ? 'EN' : 'FR' }}
                    </a>
                    <ul class="dropdown-menu dropdown-menu-end">
                        <li><a class="dropdown-item {% if app.request.locale == 'fr' %}active{% endif %}" href="{{ path('app_set_locale', {locale: 'fr'}) }}">🇫🇷 Français</a></li>
                        <li><a class="dropdown-item {% if app.request.locale == 'en' %}active{% endif %}" href="{{ path('app_set_locale', {locale: 'en'}) }}">🇬🇧 English</a></li>
                    </ul>
                </li>
                {% if is_granted('ROLE_USER') %}
                    <li class="nav-item me-2">
                        <a class="nav-link position-relative" href="{{ path('app_locataire_notifications') }}">
                            <i class="bi bi-bell-fill"></i>
                            <span class="position-absolute top-0 start-100 translate-middle badge rounded-pill bg-danger badge-notif" id="notifCount" style="display:none">0</span>
                        </a>
                    </li>
                    <li class="nav-item dropdown">
                        <a class="nav-link dropdown-toggle" href="#" data-bs-toggle="dropdown">
                            {% if app.user.photoProfil %}
                                <img src="{{ asset('uploads/profils/' ~ app.user.photoProfil) }}" alt="Profil" width="28" height="28" class="rounded-circle me-1" loading="lazy">
                            {% else %}
                                <i class="bi bi-person-circle"></i>
                            {% endif %}
                            {{ app.user.prenom }}
                        </a>
                        <ul class="dropdown-menu dropdown-menu-end">
                            <li><a class="dropdown-item" href="{{ path('app_profil') }}"><i class="bi bi-person-gear"></i> {{ 'nav.profil'|trans }}</a></li>
                            <li><hr class="dropdown-divider"></li>
                            <li><a class="dropdown-item" href="{{ path('app_logout') }}"><i class="bi bi-box-arrow-right"></i> {{ 'nav.logout'|trans }}</a></li>
                        </ul>
                    </li>
                {% else %}
                    <li class="nav-item"><a class="nav-link" href="{{ path('app_login') }}"><i class="bi bi-box-arrow-in-right"></i> {{ 'nav.login'|trans }}</a></li>
                    <li class="nav-item"><a class="btn btn-primary btn-sm ms-2" href="{{ path('app_register') }}">{{ 'nav.register'|trans }}</a></li>
                {% endif %}
            </ul>
        </div>
    </div>
</nav>

<div class="container mt-3">
    {% for type, messages in app.flashes %}
        {% for message in messages %}
            <div class="alert alert-{{ type == 'error' ? 'danger' : type }} alert-dismissible fade show" role="alert">
                {{ message }}<button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
        {% endfor %}
    {% endfor %}
</div>

{% block body %}{% endblock %}

<footer class="mt-5 py-4" style="background-color: var(--dark); color: #adb5bd;">
    <div class="container text-center">
        <p class="mb-1">&copy; {{ 'now'|date('Y') }} {{ 'app.name'|trans }}</p>
        <small>
            <a href="{{ path('app_annonces') }}" class="text-secondary me-3">{{ 'nav.annonces'|trans }}</a>
            <a href="{{ path('app_home') }}#faq" class="text-secondary">{{ 'nav.footer_faq'|trans }}</a>
        </small>
    </div>
</footer>

{# Bootstrap JS différé – Green IT #}
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"
        crossorigin="anonymous" defer></script>

{% if is_granted('ROLE_USER') %}
<script defer>
document.addEventListener('DOMContentLoaded', () => {
    fetch('{{ path('app_notifications_count') }}')
        .then(r => r.json())
        .then(data => {
            if (data.count > 0) {
                const b = document.getElementById('notifCount');
                if (b) { b.textContent = data.count; b.style.display = ''; }
            }
        }).catch(() => {});

    fetch('{{ path('app_messages_count') }}')
        .then(r => r.json())
        .then(data => {
            if (data.count > 0) {
                const b = document.getElementById('msgBadge');
                if (b) { b.textContent = data.count; b.style.display = ''; }
            }
        }).catch(() => {});
});
</script>
{% endif %}

{% block javascripts %}{% endblock %}
</body>
</html>
