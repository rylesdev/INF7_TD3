{% extends 'base.html.twig' %}
{% block title %}{{ 'profil.new_password'|trans }}{% endblock %}

{% block body %}
<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-md-5">
            <div class="card p-4">
                <h1 class="h4 mb-4"><i class="bi bi-shield-lock text-primary"></i> {{ 'profil.new_password'|trans }}</h1>
                <form method="post">
                    <input type="hidden" name="token" value="{{ token }}">
                    <div class="mb-3">
                        <label class="form-label">{{ 'profil.new_password'|trans }} <small class="text-muted">(8 {{ 'profil.chars_min'|trans }})</small></label>
                        <input type="password" name="password" class="form-control" required minlength="8" autofocus>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">{{ 'profil.confirm_password'|trans }}</label>
                        <input type="password" name="confirm" class="form-control" required minlength="8">
                    </div>
                    <button type="submit" class="btn btn-primary w-100">{{ 'forms.update_password'|trans }}</button>
                </form>
            </div>
        </div>
    </div>
</div>
{% endblock %}
