{% extends 'base.html.twig' %}
{% block title %}Mot de passe oublié{% endblock %}

{% block body %}
<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-md-5">
            <div class="card p-4">
                <h1 class="h4 mb-4"><i class="bi bi-key text-warning"></i> Mot de passe oublié</h1>
                {% if submitted %}
                    <div class="alert alert-success">
                        <i class="bi bi-check-circle"></i>
                        Si un compte existe avec cet email, vous recevrez les instructions de réinitialisation.
                        <br><small>(Simulation – aucun email réel envoyé en environnement de développement)</small>
                    </div>
                    <a href="{{ path('app_reset_password') }}" class="btn btn-primary">Réinitialiser maintenant</a>
                {% else %}
                    <p class="text-muted mb-4">Saisissez votre email pour recevoir un lien de réinitialisation.</p>
                    <form method="post">
                        <div class="mb-3">
                            <label class="form-label">Email</label>
                            <input type="email" name="email" class="form-control" required>
                        </div>
                        <button type="submit" class="btn btn-warning w-100">Envoyer</button>
                    </form>
                {% endif %}
                <div class="text-center mt-3">
                    <a href="{{ path('app_login') }}" class="text-muted small">Retour à la connexion</a>
                </div>
            </div>
        </div>
    </div>
</div>
{% endblock %}
