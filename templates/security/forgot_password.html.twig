{% extends 'base.html.twig' %}
{% block title %}Mot de passe oublié{% endblock %}

{% block body %}
<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-md-5">
            <div class="card p-4">
                <h1 class="h4 mb-4"><i class="bi bi-key text-warning"></i> Mot de passe oublié</h1>

                <p class="text-muted mb-4">Saisissez votre email pour recevoir un lien de réinitialisation.</p>

                <form method="post">
                    <div class="mb-3">
                        <label class="form-label">Email</label>
                        <input type="email" name="email" class="form-control" required autofocus>
                    </div>
                    <button type="submit" class="btn btn-warning w-100">Envoyer le lien</button>
                </form>

                <div class="text-center mt-3">
                    <a href="{{ path('app_login') }}" class="text-muted small">Retour à la connexion</a>
                </div>
            </div>
        </div>
    </div>
</div>
{% endblock %}
