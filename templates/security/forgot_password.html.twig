{% extends 'base.html.twig' %}
{% block title %}{{ 'security.login.forgot'|trans }}{% endblock %}

{% block body %}
<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-md-5">
            <div class="card p-4">
                <h1 class="h4 mb-4"><i class="bi bi-key text-warning"></i> {{ 'security.login.forgot'|trans }}</h1>
                <p class="text-muted mb-4">{{ 'security.login.email'|trans }}</p>
                <form method="post">
                    <div class="mb-3">
                        <label class="form-label">{{ 'security.login.email'|trans }}</label>
                        <input type="email" name="email" class="form-control" required autofocus>
                    </div>
                    <button type="submit" class="btn btn-warning w-100">{{ 'forms.send_link'|trans }}</button>
                </form>
                <div class="text-center mt-3">
                    <a href="{{ path('app_login') }}" class="text-muted small">{{ 'forms.back_to_login'|trans }}</a>
                </div>
            </div>
        </div>
    </div>
</div>
{% endblock %}
