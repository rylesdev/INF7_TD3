{% extends 'base.html.twig' %}
{% block title %}Inscription{% endblock %}

{% block body %}
<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card p-4">
                <h1 class="h3 mb-4 text-center"><i class="bi bi-person-plus text-primary"></i> Créer un compte</h1>
                {{ form_start(form, {attr: {class: 'needs-validation', novalidate: true}}) }}
                    <div class="row">
                        <div class="col-md-6 mb-3">{{ form_label(form.prenom) }}{{ form_widget(form.prenom) }}{{ form_errors(form.prenom) }}</div>
                        <div class="col-md-6 mb-3">{{ form_label(form.nom) }}{{ form_widget(form.nom) }}{{ form_errors(form.nom) }}</div>
                    </div>
                    <div class="mb-3">{{ form_label(form.email) }}{{ form_widget(form.email) }}{{ form_errors(form.email) }}</div>
                    <div class="mb-3">{{ form_label(form.telephone) }}{{ form_widget(form.telephone) }}{{ form_errors(form.telephone) }}</div>
                    <div class="mb-3">
                        {{ form_label(form.role) }}
                        <div class="d-flex gap-4 mt-1">{{ form_widget(form.role) }}</div>
                        {{ form_errors(form.role) }}
                    </div>
                    <div class="mb-3">{{ form_label(form.plainPassword.first) }}{{ form_widget(form.plainPassword.first) }}{{ form_errors(form.plainPassword.first) }}</div>
                    <div class="mb-3">{{ form_label(form.plainPassword.second) }}{{ form_widget(form.plainPassword.second) }}{{ form_errors(form.plainPassword.second) }}</div>
                    <button type="submit" class="btn btn-primary w-100">Créer mon compte</button>
                {{ form_end(form) }}
                <div class="text-center mt-3">
                    <span class="text-muted small">Déjà inscrit ?</span>
                    <a href="{{ path('app_login') }}" class="small">Se connecter</a>
                </div>
            </div>
        </div>
    </div>
</div>
{% endblock %}
