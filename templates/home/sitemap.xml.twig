<?xml version="1.0" encoding="UTF-8"?>
<urlset xmlns="http://www.sitemaps.org/schemas/sitemap/0.9">
    <url>
        <loc>{{ app.request.schemeAndHttpHost }}{{ path('app_home') }}</loc>
        <changefreq>weekly</changefreq>
        <priority>1.0</priority>
    </url>
    <url>
        <loc>{{ app.request.schemeAndHttpHost }}{{ path('app_annonces') }}</loc>
        <changefreq>daily</changefreq>
        <priority>0.9</priority>
    </url>
    {% for annonce in annonces %}
    <url>
        <loc>{{ app.request.schemeAndHttpHost }}{{ path('app_annonce_show', {id: annonce.id}) }}</loc>
        <lastmod>{{ annonce.updatedAt|date('Y-m-d') }}</lastmod>
        <changefreq>weekly</changefreq>
        <priority>0.7</priority>
    </url>
    {% endfor %}
    <url>
        <loc>{{ app.request.schemeAndHttpHost }}{{ path('app_login') }}</loc>
        <changefreq>yearly</changefreq>
        <priority>0.3</priority>
    </url>
    <url>
        <loc>{{ app.request.schemeAndHttpHost }}{{ path('app_register') }}</loc>
        <changefreq>yearly</changefreq>
        <priority>0.4</priority>
    </url>
</urlset>
