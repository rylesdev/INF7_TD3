{% extends 'base.html.twig' %}

{% block title %}{{ 'nav.home'|trans }}{% endblock %}
{% block meta_description %}Colocation.com – {{ 'app.tagline'|trans }}{% endblock %}

{% block body %}

{# Hero Section #}
<section class="hero-section text-center">
    <div class="container">
        <h1 class="display-4 fw-bold mb-3"><i class="bi bi-house-heart-fill"></i> {{ 'app.name'|trans }}</h1>
        {% if is_granted('ROLE_PROPRIETAIRE') %}
            <p class="lead mb-4">{{ 'home.hero.welcome_proprio'|trans({'%name%': app.user.prenom}) }}</p>
            <a href="{{ path('app_proprietaire_dashboard') }}" class="btn btn-light btn-lg me-3">
                <i class="bi bi-speedometer2"></i> {{ 'home.hero.btn_dashboard'|trans }}
            </a>
            <a href="{{ path('app_annonce_new') }}" class="btn btn-outline-light btn-lg">
                <i class="bi bi-plus-circle"></i> {{ 'home.hero.btn_new_listing'|trans }}
            </a>
        {% elseif is_granted('ROLE_USER') %}
            <p class="lead mb-4">{{ 'home.hero.welcome_tenant'|trans({'%name%': app.user.prenom}) }}</p>
            <a href="{{ path('app_locataire_dashboard') }}" class="btn btn-light btn-lg me-3">
                <i class="bi bi-speedometer2"></i> {{ 'home.hero.btn_tenant_space'|trans }}
            </a>
            <a href="{{ path('app_annonces') }}" class="btn btn-outline-light btn-lg">
                <i class="bi bi-search"></i> {{ 'home.hero.btn_see_listings'|trans }}
            </a>
        {% else %}
            <p class="lead mb-4">{{ 'home.hero.tagline'|trans|nl2br }}</p>
            <a href="{{ path('app_annonces') }}" class="btn btn-light btn-lg me-3">
                <i class="bi bi-search"></i> {{ 'home.hero.btn_see_listings'|trans }}
            </a>
            <a href="{{ path('app_register') }}" class="btn btn-outline-light btn-lg">
                <i class="bi bi-person-plus"></i> {{ 'home.hero.btn_register_free'|trans }}
            </a>
        {% endif %}
    </div>
</section>

{# Stats #}
<section class="py-4 bg-white border-bottom">
    <div class="container">
        <div class="row text-center g-4">
            <div class="col-6 col-md-3">
                <div class="fw-bold display-6 text-primary">3 200+</div>
                <div class="text-muted small">{{ 'home.stats.tenants'|trans }}</div>
            </div>
            <div class="col-6 col-md-3">
                <div class="fw-bold display-6 text-primary">850+</div>
                <div class="text-muted small">{{ 'home.stats.owners'|trans }}</div>
            </div>
            <div class="col-6 col-md-3">
                <div class="fw-bold display-6 text-primary">12 000+</div>
                <div class="text-muted small">{{ 'home.stats.rents'|trans }}</div>
            </div>
            <div class="col-6 col-md-3">
                <div class="fw-bold display-6 text-primary">4,8 / 5</div>
                <div class="text-muted small">{{ 'home.stats.satisfaction'|trans }}</div>
            </div>
        </div>
    </div>
</section>

{# Propriétaires / Locataires #}
<section class="py-5">
    <div class="container">
        {% if is_granted('ROLE_PROPRIETAIRE') %}
        <h2 class="text-center fw-bold mb-5">{{ 'home.features.your_owner_space'|trans }}</h2>
        <div class="row g-4 justify-content-center">
            <div class="col-md-8">
                <div class="card h-100 p-4 border-primary" style="border-width:2px !important;">
                    <div class="d-flex align-items-center mb-3">
                        <i class="bi bi-building text-primary display-5 me-3"></i>
                        <h3 class="fw-bold mb-0 h4">{{ 'home.features.what_you_can_do'|trans }}</h3>
                    </div>
                    <ul class="list-unstyled mb-4">
                        <li class="mb-2"><i class="bi bi-check-circle-fill text-success me-2"></i>{{ 'home.features.owner_1'|trans }}</li>
                        <li class="mb-2"><i class="bi bi-check-circle-fill text-success me-2"></i>{{ 'home.features.owner_2'|trans }}</li>
                        <li class="mb-2"><i class="bi bi-check-circle-fill text-success me-2"></i>{{ 'home.features.owner_3'|trans }}</li>
                        <li class="mb-2"><i class="bi bi-check-circle-fill text-success me-2"></i>{{ 'home.features.owner_4'|trans }}</li>
                        <li class="mb-2"><i class="bi bi-check-circle-fill text-success me-2"></i>{{ 'home.features.owner_5b'|trans }}</li>
                    </ul>
                    <div class="d-flex gap-2 mt-auto">
                        <a href="{{ path('app_proprietaire_dashboard') }}" class="btn btn-primary">{{ 'home.features.owner_btn_dashboard'|trans }}</a>
                        <a href="{{ path('app_proprietaire_colocations') }}" class="btn btn-outline-primary">{{ 'home.features.owner_btn_colocations'|trans }}</a>
                    </div>
                </div>
            </div>
        </div>
        {% elseif is_granted('ROLE_USER') %}
        <h2 class="text-center fw-bold mb-5">{{ 'home.features.your_tenant_space'|trans }}</h2>
        <div class="row g-4 justify-content-center">
            <div class="col-md-8">
                <div class="card h-100 p-4 border-success" style="border-width:2px !important;">
                    <div class="d-flex align-items-center mb-3">
                        <i class="bi bi-house-door text-success display-5 me-3"></i>
                        <h3 class="fw-bold mb-0 h4">{{ 'home.features.what_you_can_do'|trans }}</h3>
                    </div>
                    <ul class="list-unstyled mb-4">
                        <li class="mb-2"><i class="bi bi-check-circle-fill text-success me-2"></i>{{ 'home.features.tenant_1'|trans }}</li>
                        <li class="mb-2"><i class="bi bi-check-circle-fill text-success me-2"></i>{{ 'home.features.tenant_2'|trans }}</li>
                        <li class="mb-2"><i class="bi bi-check-circle-fill text-success me-2"></i>{{ 'home.features.tenant_3'|trans }}</li>
                        <li class="mb-2"><i class="bi bi-check-circle-fill text-success me-2"></i>{{ 'home.features.tenant_4'|trans }}</li>
                        <li class="mb-2"><i class="bi bi-check-circle-fill text-success me-2"></i>{{ 'home.features.tenant_5'|trans }}</li>
                    </ul>
                    <div class="d-flex gap-2 mt-auto">
                        <a href="{{ path('app_locataire_dashboard') }}" class="btn btn-success">{{ 'home.features.tenant_btn_space'|trans }}</a>
                        <a href="{{ path('app_annonces') }}" class="btn btn-outline-success">{{ 'home.features.tenant_btn_listings'|trans }}</a>
                    </div>
                </div>
            </div>
        </div>
        {% else %}
        <h2 class="text-center fw-bold mb-5">{{ 'home.features.for_all'|trans }}</h2>
        <div class="row g-4">
            <div class="col-md-6">
                <div class="card h-100 p-4 border-primary" style="border-width:2px !important;">
                    <div class="d-flex align-items-center mb-3">
                        <i class="bi bi-building text-primary display-5 me-3"></i>
                        <h3 class="fw-bold mb-0 h4">{{ 'home.features.owner_title'|trans }}</h3>
                    </div>
                    <ul class="list-unstyled mb-4">
                        <li class="mb-2"><i class="bi bi-check-circle-fill text-success me-2"></i>{{ 'home.features.owner_1'|trans }}</li>
                        <li class="mb-2"><i class="bi bi-check-circle-fill text-success me-2"></i>{{ 'home.features.owner_2'|trans }}</li>
                        <li class="mb-2"><i class="bi bi-check-circle-fill text-success me-2"></i>{{ 'home.features.owner_3'|trans }}</li>
                        <li class="mb-2"><i class="bi bi-check-circle-fill text-success me-2"></i>{{ 'home.features.owner_4'|trans }}</li>
                        <li class="mb-2"><i class="bi bi-check-circle-fill text-success me-2"></i>{{ 'home.features.owner_5'|trans }}</li>
                    </ul>
                    <a href="{{ path('app_register') }}" class="btn btn-primary mt-auto">{{ 'home.features.owner_btn_register'|trans }}</a>
                </div>
            </div>
            <div class="col-md-6">
                <div class="card h-100 p-4 border-success" style="border-width:2px !important;">
                    <div class="d-flex align-items-center mb-3">
                        <i class="bi bi-house-door text-success display-5 me-3"></i>
                        <h3 class="fw-bold mb-0 h4">{{ 'home.features.tenant_title'|trans }}</h3>
                    </div>
                    <ul class="list-unstyled mb-4">
                        <li class="mb-2"><i class="bi bi-check-circle-fill text-success me-2"></i>{{ 'home.features.tenant_1'|trans }}</li>
                        <li class="mb-2"><i class="bi bi-check-circle-fill text-success me-2"></i>{{ 'home.features.tenant_2'|trans }}</li>
                        <li class="mb-2"><i class="bi bi-check-circle-fill text-success me-2"></i>{{ 'home.features.tenant_3'|trans }}</li>
                        <li class="mb-2"><i class="bi bi-check-circle-fill text-success me-2"></i>{{ 'home.features.tenant_4'|trans }}</li>
                        <li class="mb-2"><i class="bi bi-check-circle-fill text-success me-2"></i>{{ 'home.features.tenant_5'|trans }}</li>
                    </ul>
                    <a href="{{ path('app_annonces') }}" class="btn btn-outline-primary mt-auto">{{ 'home.features.tenant_btn_find'|trans }}</a>
                </div>
            </div>
        </div>
        {% endif %}
    </div>
</section>

{# Propriétaires bien notés #}
{% if proprietaires_notes|length > 0 %}
<section class="py-5 bg-white">
    <div class="container">
        <h2 class="text-center fw-bold mb-5"><i class="bi bi-star-fill text-warning me-2"></i>{{ 'home.owners.title'|trans }}</h2>
        <div class="row g-4 justify-content-center">
            {% for p in proprietaires_notes %}
            <div class="col-md-4">
                <a href="{{ path('app_profil_proprietaire', {id: p.id}) }}" class="text-decoration-none text-dark">
                    <div class="card p-4 h-100 text-center">
                        {% if p.photo_profil %}
                            <img src="{{ asset('uploads/profils/' ~ p.photo_profil) }}"
                                 width="72" height="72" class="rounded-circle mx-auto mb-3"
                                 style="object-fit:cover;" loading="lazy">
                        {% else %}
                            <div class="rounded-circle bg-primary d-flex align-items-center justify-content-center mx-auto mb-3 text-white fw-bold"
                                 style="width:72px;height:72px;font-size:1.5rem;">
                                {{ p.prenom|slice(0,1)|upper }}
                            </div>
                        {% endif %}
                        <div class="fw-bold mb-1">{{ p.prenom }} {{ p.nom|slice(0,1) }}.</div>
                        <div class="text-muted small mb-2">{{ 'home.owners.role'|trans }}</div>
                        <div class="mb-1">
                            {% for i in 1..5 %}
                                <i class="bi bi-star{{ i <= p.moyenne ? '-fill text-warning' : ' text-muted' }}"></i>
                            {% endfor %}
                        </div>
                        <div class="text-muted small">{{ p.moyenne }}/5 ({{ p.nb_avis }} {{ 'home.owners.reviews'|trans }})</div>
                    </div>
                </a>
            </div>
            {% endfor %}
        </div>
    </div>
</section>
{% endif %}

{# Annonces récentes #}
{% if annonces_recentes|length > 0 %}
<section class="py-5 bg-white">
    <div class="container">
        <h2 class="fw-bold mb-4">{{ 'home.listings.title'|trans }}</h2>
        <div class="row g-4">
            {% for annonce in annonces_recentes %}
            <div class="col-md-4">
                <div class="card h-100">
                    {% if annonce.premierPhoto %}
                        <img src="{{ asset('uploads/annonces/' ~ annonce.premierPhoto.filename) }}"
                             class="card-img-top" alt="{{ annonce.premierPhoto.alt }}"
                             style="height:200px;object-fit:cover;" loading="lazy">
                    {% else %}
                        <div class="card-img-top bg-secondary d-flex align-items-center justify-content-center" style="height:200px;">
                            <i class="bi bi-house text-white display-4"></i>
                        </div>
                    {% endif %}
                    <div class="card-body">
                        <h5 class="card-title">{{ annonce.titre }}</h5>
                        <p class="text-muted small"><i class="bi bi-geo-alt"></i> {{ annonce.localisation }}</p>
                        <p class="fw-bold text-primary fs-5">{{ annonce.prix }}{{ 'home.listings.per_month'|trans }}</p>
                    </div>
                    <div class="card-footer bg-transparent">
                        <a href="{{ path('app_annonce_show', {id: annonce.id}) }}" class="btn btn-primary w-100">
                            {{ 'home.listings.btn_detail'|trans }}
                        </a>
                    </div>
                </div>
            </div>
            {% endfor %}
        </div>
        <div class="text-center mt-4">
            <a href="{{ path('app_annonces') }}" class="btn btn-outline-primary">{{ 'home.listings.btn_all'|trans }}</a>
        </div>
    </div>
</section>
{% endif %}

{# FAQ #}
<section class="py-5" id="faq">
    <div class="container">
        <h2 class="fw-bold text-center mb-5">{{ 'home.faq.title'|trans }}</h2>
        <div class="accordion" id="faqAccordion">
            {% if is_granted('ROLE_PROPRIETAIRE') %}
            {% set faqs = [
                {q: 'home.faq.owner_q1'|trans, a: 'home.faq.owner_a1'|trans},
                {q: 'home.faq.owner_q2'|trans, a: 'home.faq.owner_a2'|trans},
                {q: 'home.faq.owner_q3'|trans, a: 'home.faq.owner_a3'|trans},
                {q: 'home.faq.owner_q4'|trans, a: 'home.faq.owner_a4'|trans},
                {q: 'home.faq.owner_q5'|trans, a: 'home.faq.owner_a5'|trans},
                {q: 'home.faq.owner_q6'|trans, a: 'home.faq.owner_a6'|trans}
            ] %}
            {% elseif is_granted('ROLE_USER') %}
            {% set faqs = [
                {q: 'home.faq.tenant_q1'|trans, a: 'home.faq.tenant_a1'|trans},
                {q: 'home.faq.tenant_q2'|trans, a: 'home.faq.tenant_a2'|trans},
                {q: 'home.faq.tenant_q3'|trans, a: 'home.faq.tenant_a3'|trans},
                {q: 'home.faq.tenant_q4'|trans, a: 'home.faq.tenant_a4'|trans},
                {q: 'home.faq.tenant_q5'|trans, a: 'home.faq.tenant_a5'|trans},
                {q: 'home.faq.tenant_q6'|trans, a: 'home.faq.tenant_a6'|trans}
            ] %}
            {% else %}
            {% set faqs = [
                {q: 'home.faq.guest_q1'|trans, a: 'home.faq.guest_a1'|trans},
                {q: 'home.faq.guest_q2'|trans, a: 'home.faq.guest_a2'|trans},
                {q: 'home.faq.guest_q3'|trans, a: 'home.faq.guest_a3'|trans},
                {q: 'home.faq.guest_q4'|trans, a: 'home.faq.guest_a4'|trans},
                {q: 'home.faq.guest_q5'|trans, a: 'home.faq.guest_a5'|trans},
                {q: 'home.faq.guest_q6'|trans, a: 'home.faq.guest_a6'|trans}
            ] %}
            {% endif %}
            {% for i, qa in faqs %}
            <div class="accordion-item">
                <h3 class="accordion-header">
                    <button class="accordion-button {{ i > 0 ? 'collapsed' : '' }}" type="button"
                            data-bs-toggle="collapse" data-bs-target="#faq{{ i }}">
                        {{ qa.q }}
                    </button>
                </h3>
                <div id="faq{{ i }}" class="accordion-collapse collapse {{ i == 0 ? 'show' : '' }}" data-bs-parent="#faqAccordion">
                    <div class="accordion-body">{{ qa.a }}</div>
                </div>
            </div>
            {% endfor %}
        </div>
    </div>
</section>

{% endblock %}
