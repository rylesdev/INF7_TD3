{% extends 'base.html.twig' %}
{% block title %}{{ 'tenant.tantiemes.title'|trans }}{% endblock %}

{% block body %}
<div class="container py-5">
    <h1 class="fw-bold mb-4"><i class="bi bi-pie-chart text-primary"></i> {{ 'tenant.tantiemes.title'|trans }}</h1>

    {% if chambre %}
    <div class="alert alert-info mb-4">
        <i class="bi bi-info-circle"></i>
        {{ 'tenant.tantiemes.room_info'|trans({'%room%': chambre.nom, '%pct%': chambre.pourcentageSurface|number_format(2), '%surface%': chambre.surface, '%total%': chambre.colocation.surfaceTotale})|raw }}
    </div>
    {% endif %}

    {% if tantiemes|length == 0 %}
        <div class="alert alert-info">{{ 'tenant.tantiemes.no_shares'|trans }}</div>
    {% else %}
    <div class="card">
        <div class="table-responsive">
            <table class="table table-hover mb-0">
                <thead class="table-light">
                    <tr>
                        <th>{{ 'tenant.tantiemes.col_charge'|trans }}</th>
                        <th>{{ 'tenant.tantiemes.col_type'|trans }}</th>
                        <th>{{ 'tenant.tantiemes.col_total_amount'|trans }}</th>
                        <th>{{ 'tenant.tantiemes.col_your_share'|trans }}</th>
                        <th>{{ 'tenant.tantiemes.col_your_amount'|trans }}</th>
                        <th>{{ 'tenant.tantiemes.col_calculated_on'|trans }}</th>
                    </tr>
                </thead>
                <tbody>
                    {% for tantieme in tantiemes %}
                    <tr>
                        <td>{{ tantieme.charge.description ?? ('Charge ' ~ tantieme.charge.libelleType) }}</td>
                        <td>{{ tantieme.charge.libelleType }}</td>
                        <td>{{ tantieme.charge.montant }}€</td>
                        <td>{{ tantieme.pourcentage|number_format(2) }}%</td>
                        <td class="fw-bold text-primary">{{ tantieme.montantDu|number_format(2) }}€</td>
                        <td>{{ tantieme.calculeLe|date('d/m/Y') }}</td>
                    </tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>
    </div>
    {% endif %}
</div>
{% endblock %}
