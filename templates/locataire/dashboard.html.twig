{% extends 'base.html.twig' %}
{% block title %}Mon tableau de bord{% endblock %}

{% block body %}
<div class="container py-5">
    <h1 class="fw-bold mb-4"><i class="bi bi-speedometer2 text-primary"></i> Tableau de bord</h1>

    {% if chambre %}
    <div class="row g-4 mb-4">
        <div class="col-md-3">
            <div class="card text-center p-3 border-primary">
                <div class="display-6 fw-bold text-primary">{{ chambre.loyerMensuel }}€</div>
                <div class="text-muted small">Loyer mensuel</div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card text-center p-3 border-{{ loyerEnRetard ? 'danger' : 'success' }}">
                <div class="display-6 fw-bold text-{{ loyerEnRetard ? 'danger' : 'success' }}">
                    {{ loyerEnRetard ? 'En retard' : 'À jour' }}
                </div>
                <div class="text-muted small">Statut loyer</div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card text-center p-3">
                <div class="display-6 fw-bold text-info">{{ tachesAFaire }}</div>
                <div class="text-muted small">Tâches à faire</div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card text-center p-3">
                <div class="display-6 fw-bold text-warning">{{ messagesNonLus }}</div>
                <div class="text-muted small">Messages non lus</div>
            </div>
        </div>
    </div>

    <div class="row g-4">
        <div class="col-md-6">
            <div class="card p-4 h-100">
                <h2 class="h5 fw-bold mb-3"><i class="bi bi-house-door text-primary"></i> Ma chambre</h2>
                <ul class="list-unstyled mb-0">
                    <li class="mb-2"><strong>Chambre :</strong> {{ chambre.nom }}</li>
                    <li class="mb-2"><strong>Surface :</strong> {{ chambre.surface }} m²</li>
                    <li class="mb-2"><strong>Colocation :</strong> {{ chambre.colocation.nom }}</li>
                    <li class="mb-2"><strong>Adresse :</strong> {{ chambre.colocation.adresse }}, {{ chambre.colocation.ville }}</li>
                    <li class="mb-2"><strong>Loyer :</strong> <span class="fw-bold text-primary">{{ chambre.loyerMensuel }}€/mois</span></li>
                </ul>
            </div>
        </div>
        <div class="col-md-6">
            <div class="card p-4 h-100">
                <h2 class="h5 fw-bold mb-3"><i class="bi bi-cash-stack text-success"></i> Derniers loyers</h2>
                {% if derniersLoyers|length > 0 %}
                <div class="list-group list-group-flush">
                    {% for loyer in derniersLoyers %}
                    <div class="list-group-item px-0 d-flex justify-content-between align-items-center">
                        <span>{{ loyer.mois }}/{{ loyer.annee }}</span>
                        <span class="badge bg-{{ loyer.statut == 'payé' ? 'success' : (loyer.statut == 'en_retard' ? 'danger' : 'warning') }}">
                            {{ loyer.statut }}
                        </span>
                        <span class="fw-bold">{{ loyer.montant }}€</span>
                    </div>
                    {% endfor %}
                </div>
                {% else %}
                <p class="text-muted">Aucun loyer enregistré.</p>
                {% endif %}
                <a href="{{ path('app_locataire_loyers') }}" class="btn btn-outline-primary btn-sm mt-3">Voir tout</a>
            </div>
        </div>
    </div>
    {% else %}
    <div class="alert alert-info">
        <i class="bi bi-info-circle"></i> Vous n'avez pas encore de chambre assignée. Contactez votre propriétaire.
    </div>
    {% endif %}

    <div class="row g-4 mt-2">
        <div class="col-md-4">
            <a href="{{ path('app_locataire_loyers') }}" class="card p-4 text-decoration-none text-dark h-100 d-flex flex-column align-items-center justify-content-center">
                <i class="bi bi-receipt display-4 text-primary mb-2"></i>
                <span class="fw-bold">Mes loyers</span>
            </a>
        </div>
        <div class="col-md-4">
            <a href="{{ path('app_locataire_quittances') }}" class="card p-4 text-decoration-none text-dark h-100 d-flex flex-column align-items-center justify-content-center">
                <i class="bi bi-file-earmark-pdf display-4 text-danger mb-2"></i>
                <span class="fw-bold">Mes quittances</span>
            </a>
        </div>
        <div class="col-md-4">
            <a href="{{ path('app_locataire_messagerie') }}" class="card p-4 text-decoration-none text-dark h-100 d-flex flex-column align-items-center justify-content-center">
                <i class="bi bi-chat-dots display-4 text-success mb-2"></i>
                <span class="fw-bold">Messagerie</span>
            </a>
        </div>
    </div>
</div>
{% endblock %}
