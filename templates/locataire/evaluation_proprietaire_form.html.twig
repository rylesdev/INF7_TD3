{% extends 'base.html.twig' %}
{% block title %}{{ 'tenant.evaluations.evaluate_owner'|trans }} — {{ proprietaire.nomComplet }}{% endblock %}

{% block body %}
<div class="container py-5" style="max-width:600px;">
    <div class="d-flex align-items-center gap-3 mb-4">
        <a href="{{ path('app_locataire_evaluations') }}" class="btn btn-outline-secondary btn-sm">
            <i class="bi bi-arrow-left"></i> {{ 'forms.back'|trans }}
        </a>
        <h1 class="h3 fw-bold mb-0">
            <i class="bi bi-star text-warning"></i> {{ 'tenant.evaluations.evaluate_owner'|trans }} — {{ proprietaire.prenom }}
        </h1>
    </div>

    <div class="card p-4">
        <p class="text-muted small mb-3">
            {{ 'owner.colocations.tenants'|trans }} : <strong>{{ colocation.nom }}</strong>
        </p>
        {{ form_start(form) }}
        <div class="mb-3">
            {{ form_label(form.note) }}
            <div class="star-rating-widget mt-1" id="evalStarWidget">
                {% for choice in form.note %}
                    {{ form_widget(choice, {attr: {class: 'star-radio'}}) }}
                    <label for="{{ choice.vars.id }}" class="star-label">★</label>
                {% endfor %}
            </div>
        </div>
        <div class="mb-3">{{ form_row(form.commentaire) }}</div>
        <div class="d-flex gap-2">
            <button type="submit" class="btn btn-primary">{{ 'forms.save'|trans }}</button>
            <a href="{{ path('app_locataire_evaluations') }}" class="btn btn-outline-secondary">{{ 'forms.cancel'|trans }}</a>
        </div>
        {{ form_end(form) }}
    </div>
</div>
{% endblock %}

{% block stylesheets %}
<style>
.star-rating-widget { display:flex; flex-direction:row-reverse; justify-content:flex-end; gap:4px; }
.star-radio { display:none; }
.star-label { font-size:2rem; color:#dee2e6; cursor:pointer; transition:color .15s; }
.star-radio:checked ~ .star-label,
.star-label:hover,
.star-label:hover ~ .star-label { color:#ffc107; }
</style>
{% endblock %}
