{% extends 'base.html.twig' %}
{% block title %}{{ 'tenant.candidatures.title'|trans }}{% endblock %}

{% block body %}
<div class="container py-5">
    <h1 class="fw-bold mb-4"><i class="bi bi-send text-primary"></i> {{ 'tenant.candidatures.title'|trans }}</h1>

    {% if candidatures|length == 0 %}
        <div class="alert alert-info">
            <i class="bi bi-info-circle"></i> {{ 'tenant.candidatures.no_applications'|trans }}
            <a href="{{ path('app_annonces') }}" class="alert-link ms-2">{{ 'tenant.candidatures.browse_listings'|trans }}</a>
        </div>
    {% else %}
    <div class="card">
        <div class="table-responsive">
            <table class="table table-hover mb-0">
                <thead class="table-light">
                    <tr>
                        <th>{{ 'tenant.candidatures.col_listing'|trans }}</th>
                        <th>{{ 'tenant.candidatures.col_colocation'|trans }}</th>
                        <th>{{ 'tenant.candidatures.col_price'|trans }}</th>
                        <th>{{ 'tenant.candidatures.col_date'|trans }}</th>
                        <th>{{ 'tenant.candidatures.col_status'|trans }}</th>
                    </tr>
                </thead>
                <tbody>
                    {% for c in candidatures %}
                    <tr>
                        <td>
                            <a href="{{ path('app_annonce_show', {id: c.annonce.id}) }}" class="text-decoration-none fw-bold">
                                {{ c.annonce.titre }}
                            </a>
                        </td>
                        <td>{{ c.annonce.colocation.nom }}<br><small class="text-muted">{{ c.annonce.colocation.ville }}</small></td>
                        <td class="fw-bold">{{ c.annonce.prix }}€/mois</td>
                        <td>{{ c.creeLe|date('d/m/Y') }}</td>
                        <td>
                            {% if c.statut == 'en_attente' %}
                                <span class="badge bg-warning text-dark"><i class="bi bi-hourglass-split"></i> {{ 'tenant.candidatures.status_pending'|trans }}</span>
                            {% elseif c.statut == 'accepte' %}
                                <span class="badge bg-success"><i class="bi bi-check-circle"></i> {{ 'tenant.candidatures.status_accepted'|trans }}</span>
                            {% else %}
                                <span class="badge bg-danger"><i class="bi bi-x-circle"></i> {{ 'tenant.candidatures.status_rejected'|trans }}</span>
                            {% endif %}
                        </td>
                    </tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>
    </div>
    {% endif %}
</div>
{% endblock %}
