<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <title>Quittance de loyer</title>
    <style>
        * { margin: 0; padding: 0; box-sizing: border-box; }
        body { font-family: DejaVu Sans, Arial, sans-serif; font-size: 12px; color: #333; padding: 30px 40px; }
        h1 { font-size: 20px; text-align: center; margin-bottom: 4px; }
        .subtitle { text-align: center; color: #666; font-size: 11px; margin-bottom: 24px; border-bottom: 2px solid #333; padding-bottom: 14px; }
        h2 { font-size: 13px; border-bottom: 1px solid #ccc; padding-bottom: 4px; margin-bottom: 10px; margin-top: 20px; color: #222; }
        h3 { font-size: 11px; color: #555; margin-bottom: 6px; }
        table { width: 100%; border-collapse: collapse; }
        .label-col { color: #666; width: 45%; padding: 3px 0; }
        .value-col { padding: 3px 0; }
        .amount { font-weight: bold; }
        .total-row td { font-weight: bold; font-size: 14px; border-top: 2px solid #333; padding-top: 8px; padding-bottom: 4px; }
        .partie { background: #f5f5f5; padding: 12px 14px; }
        .partie-cell { width: 48%; vertical-align: top; }
        .spacer-cell { width: 4%; }
        .attestation { margin-top: 20px; line-height: 1.6; }
        .signature-table { width: 100%; margin-top: 40px; }
        .signature-box { border-top: 1px solid #999; padding-top: 6px; text-align: center; font-size: 11px; width: 220px; }
        .footer { margin-top: 40px; font-size: 10px; color: #999; text-align: center; border-top: 1px solid #eee; padding-top: 12px; }
    </style>
</head>
<body>

    <h1>QUITTANCE DE LOYER</h1>
    <div class="subtitle">Colocation.com – Gestion locative</div>

    {# Bailleur / Locataire #}
    <table>
        <tr>
            <td class="partie-cell">
                <div class="partie">
                    <h3>BAILLEUR</h3>
                    {% set proprio = quittance.loyer.colocation.proprietaire %}
                    {% if proprio %}
                        <strong>{{ proprio.nomComplet }}</strong><br>
                        {{ quittance.loyer.colocation.adresse }}<br>
                        {{ quittance.loyer.colocation.codePostal }} {{ quittance.loyer.colocation.ville }}
                    {% endif %}
                </div>
            </td>
            <td class="spacer-cell"></td>
            <td class="partie-cell">
                <div class="partie">
                    <h3>LOCATAIRE</h3>
                    {% set chambre = quittance.loyer.chambre %}
                    {% if chambre and chambre.locataire %}
                        <strong>{{ chambre.locataire.nomComplet }}</strong><br>
                        {{ quittance.loyer.colocation.adresse }}<br>
                        {{ quittance.loyer.colocation.codePostal }} {{ quittance.loyer.colocation.ville }}
                    {% endif %}
                </div>
            </td>
        </tr>
    </table>

    <h2>BIEN LOUÉ</h2>
    <table>
        <tr>
            <td class="label-col">Colocation :</td>
            <td class="value-col">{{ quittance.loyer.colocation.nom }}</td>
        </tr>
        {% if quittance.loyer.chambre %}
        <tr>
            <td class="label-col">Chambre :</td>
            <td class="value-col">{{ quittance.loyer.chambre.nom }} ({{ quittance.loyer.chambre.surface }} m²)</td>
        </tr>
        {% endif %}
        <tr>
            <td class="label-col">Période :</td>
            <td class="value-col">{{ quittance.periodeDebut|date('d/m/Y') }} au {{ quittance.periodeFin|date('d/m/Y') }}</td>
        </tr>
    </table>

    <h2>DÉTAIL DU PAIEMENT</h2>
    <table>
        <tr>
            <td class="label-col">Loyer nu :</td>
            <td class="value-col amount">{{ quittance.montantLoyer }}€</td>
        </tr>
        <tr>
            <td class="label-col">Charges :</td>
            <td class="value-col amount">{{ quittance.montantCharges }}€</td>
        </tr>
        <tr class="total-row">
            <td>TOTAL RÉGLÉ :</td>
            <td class="amount">{{ quittance.montantTotal }}€</td>
        </tr>
    </table>

    <div class="attestation">
        {% set locataireNom %}{% if quittance.loyer.chambre and quittance.loyer.chambre.locataire %}{{ quittance.loyer.chambre.locataire.nomComplet }}{% endif %}{% endset %}
        <p>
            Je soussigné(e), bailleur du logement désigné ci-dessus, déclare avoir reçu de
            <strong>{{ locataireNom }}</strong>
            la somme de <strong>{{ quittance.montantTotal }}€</strong>
            au titre du loyer et des charges du mois de
            {% set moisFr = ['janvier','février','mars','avril','mai','juin','juillet','août','septembre','octobre','novembre','décembre'] %}
            <strong>{{ moisFr[quittance.periodeDebut|date('n') - 1] }} {{ quittance.periodeDebut|date('Y') }}</strong>,
            et lui en donne quittance, sous réserve de tous mes droits.
        </p>
    </div>

    <table class="signature-table">
        <tr>
            <td style="text-align:right; padding-right: 10px; font-size:11px; vertical-align:bottom;">
                Fait le {{ quittance.genereeAt ? quittance.genereeAt|date('d/m/Y') : 'N/A' }}
            </td>
        </tr>
        <tr>
            <td style="text-align:right; padding-top: 30px;">
                <div class="signature-box" style="display:inline-block;">Signature du bailleur</div>
            </td>
        </tr>
    </table>

    <div class="footer">
        Document généré automatiquement par Colocation.com{% if quittance.genereeAt %}, le {{ quittance.genereeAt|date('d/m/Y à H:i') }}{% endif %}
    </div>

</body>
</html>
