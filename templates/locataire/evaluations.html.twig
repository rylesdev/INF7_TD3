{% extends 'base.html.twig' %}
{% block title %}{{ 'tenant.evaluations.title'|trans }}{% endblock %}

{% block body %}
<div class="container py-5">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1 class="h3 fw-bold mb-0"><i class="bi bi-star-fill text-warning"></i> {{ 'tenant.evaluations.title'|trans }}</h1>
        {% if chambre and chambre.colocation and chambre.colocation.proprietaire %}
        <a href="{{ path('app_locataire_evaluer_proprietaire', {id: chambre.colocation.proprietaire.id}) }}"
           class="btn btn-outline-warning btn-sm">
            <i class="bi bi-star"></i> {{ 'tenant.evaluations.evaluate_owner'|trans }}
        </a>
        {% endif %}
    </div>

    {% if evaluations|length > 0 %}
    <div class="card mb-4 border-warning">
        <div class="card-body text-center">
            <div class="display-4 fw-bold text-warning">{{ moyenne }}</div>
            <div class="text-muted">{{ 'tenant.evaluations.avg_label'|trans({'%count%': evaluations|length}) }}</div>
            <div class="mt-2">
                {% for i in 1..5 %}
                    <i class="bi bi-star{{ i <= moyenne|round ? '-fill text-warning' : ' text-muted' }} fs-4"></i>
                {% endfor %}
            </div>
        </div>
    </div>

    <div class="row g-4">
        {% for eval in evaluations %}
        <div class="col-md-6">
            <div class="card h-100">
                <div class="card-body">
                    <div class="d-flex align-items-center gap-3 mb-3">
                        <a href="{{ path('app_profil_proprietaire', {id: eval.proprietaire.id}) }}" class="text-decoration-none flex-shrink-0">
                            <div class="rounded-circle bg-secondary d-flex align-items-center justify-content-center text-white fw-bold"
                                 style="width:44px;height:44px">
                                {{ eval.proprietaire.prenom|slice(0,1)|upper }}{{ eval.proprietaire.nom|slice(0,1)|upper }}
                            </div>
                        </a>
                        <div>
                            <a href="{{ path('app_profil_proprietaire', {id: eval.proprietaire.id}) }}" class="fw-semibold text-decoration-none text-dark">{{ eval.proprietaire.nomComplet }}</a>
                            <div class="text-muted small"><i class="bi bi-building"></i> {{ eval.colocation.nom }}</div>
                        </div>
                    </div>
                    <div class="mb-2">
                        {% for i in 1..5 %}
                            <i class="bi bi-star{{ i <= eval.note ? '-fill text-warning' : ' text-muted' }}"></i>
                        {% endfor %}
                        <span class="ms-1 badge bg-warning text-dark">{{ eval.note }}/5</span>
                    </div>
                    {% if eval.commentaire %}
                    <blockquote class="blockquote small border-start border-warning ps-3 mt-3 text-muted">
                        {{ eval.commentaire }}
                    </blockquote>
                    {% else %}
                    <p class="text-muted small mt-2">{{ 'tenant.evaluations.no_comment'|trans }}</p>
                    {% endif %}
                    <div class="text-muted small mt-2">
                        <i class="bi bi-calendar3"></i>
                        {{ eval.creeLe ? eval.creeLe|date('d/m/Y') : '-' }}
                    </div>
                </div>
            </div>
        </div>
        {% endfor %}
    </div>
    {% else %}
    <div class="card mb-4">
        <div class="card-body text-center text-muted py-5">
            <i class="bi bi-star display-4 mb-3 d-block"></i>
            <p>{{ 'tenant.evaluations.no_reviews'|trans }}</p>
        </div>
    </div>
    {% endif %}

    {% if evalDonnees|length > 0 %}
    <h2 class="h5 fw-bold mt-4 mb-3"><i class="bi bi-star text-info"></i> {{ 'tenant.evaluations.reviews_given'|trans }}</h2>
    <div class="row g-4">
        {% for eval in evalDonnees %}
        <div class="col-md-6">
            <div class="card h-100">
                <div class="card-body">
                    <div class="d-flex align-items-center gap-3 mb-2">
                        <div>
                            <a href="{{ path('app_profil_proprietaire', {id: eval.proprietaire.id}) }}" class="fw-semibold text-decoration-none">
                                {{ eval.proprietaire.nomComplet }}
                            </a>
                            <div class="text-muted small"><i class="bi bi-building"></i> {{ eval.colocation.nom }}</div>
                        </div>
                    </div>
                    <div class="mb-2">
                        {% for i in 1..5 %}
                            <i class="bi bi-star{{ i <= eval.note ? '-fill text-warning' : ' text-muted' }}"></i>
                        {% endfor %}
                    </div>
                    {% if eval.commentaire %}
                        <p class="small text-muted mb-0">{{ eval.commentaire }}</p>
                    {% endif %}
                    <div class="text-muted small mt-2">{{ eval.creeLe|date('d/m/Y') }}</div>
                </div>
            </div>
        </div>
        {% endfor %}
    </div>
    {% endif %}
</div>
{% endblock %}
