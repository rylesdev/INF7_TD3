{% extends 'base.html.twig' %}
{% block title %}Mes loyers{% endblock %}

{% block body %}
<div class="container py-5">
    <h1 class="fw-bold mb-4"><i class="bi bi-receipt text-primary"></i> Mes loyers</h1>

    {% if loyers|length == 0 %}
        <div class="alert alert-info">Aucun loyer enregistré.</div>
    {% else %}
    <div class="card">
        <div class="table-responsive">
            <table class="table table-hover mb-0">
                <thead class="table-light">
                    <tr>
                        <th>Colocation</th>
                        <th>Chambre</th>
                        <th>Période</th>
                        <th>Montant</th>
                        <th>Échéance</th>
                        <th>Paiement</th>
                        <th>Statut</th>
                        <th>Quittance</th>
                        <th>Action</th>
                    </tr>
                </thead>
                <tbody>
                    {% set statutLabels = {'payé': 'Payé', 'impayé': 'Impayé', 'en_retard': 'En retard'} %}
                    {% for loyer in loyers %}
                    <tr>
                        <td>{{ loyer.colocation ? loyer.colocation.nom : '-' }}</td>
                        <td>{{ loyer.chambre ? loyer.chambre.nom : '-' }}</td>
                        <td>{{ loyer.mois }}/{{ loyer.annee }}</td>
                        <td class="fw-bold">{{ loyer.montant }}€</td>
                        <td>{{ loyer.dateEcheance|date('d/m/Y') }}</td>
                        <td>{{ loyer.datePaiement ? loyer.datePaiement|date('d/m/Y') : '-' }}</td>
                        <td>
                            <span class="badge bg-{{ loyer.statut == 'payé' ? 'success' : (loyer.statut == 'en_retard' ? 'danger' : 'warning') }}">
                                {{ statutLabels[loyer.statut] ?? loyer.statut }}
                            </span>
                        </td>
                        <td>
                            {% if loyer.quittance %}
                                <a href="{{ path('app_locataire_quittance_pdf', {id: loyer.quittance.id}) }}" class="btn btn-sm btn-outline-danger" target="_blank">
                                    <i class="bi bi-file-earmark-pdf"></i> PDF
                                </a>
                            {% else %}
                                <span class="text-muted small">Non disponible</span>
                            {% endif %}
                        </td>
                        <td>
                            {% if loyer.statut != 'payé' %}
                            <form method="POST" action="{{ path('app_locataire_loyer_payer', {id: loyer.id}) }}" onsubmit="return confirm('Simuler le paiement de ce loyer ?')">
                                <input type="hidden" name="_token" value="{{ csrf_token('payer_loyer_' ~ loyer.id) }}">
                                <button type="submit" class="btn btn-sm btn-success">
                                    <i class="bi bi-credit-card"></i> Payer
                                </button>
                            </form>
                            {% else %}
                                <span class="text-success small"><i class="bi bi-check-circle"></i> Payé</span>
                            {% endif %}
                        </td>
                    </tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>
    </div>
    {% endif %}
</div>
{% endblock %}
