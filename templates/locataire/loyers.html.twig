{% extends 'base.html.twig' %}
{% block title %}{{ 'tenant.loyers.title'|trans }}{% endblock %}

{% block body %}
<div class="container py-5">
    <h1 class="fw-bold mb-4"><i class="bi bi-receipt text-primary"></i> {{ 'tenant.loyers.title'|trans }}</h1>

    {% if loyers|length == 0 %}
        <div class="alert alert-info">{{ 'tenant.loyers.no_rents'|trans }}</div>
    {% else %}
    <div class="card">
        <div class="table-responsive">
            <table class="table table-hover mb-0">
                <thead class="table-light">
                    <tr>
                        <th>{{ 'tenant.loyers.col_colocation'|trans }}</th>
                        <th>{{ 'tenant.loyers.col_room'|trans }}</th>
                        <th>{{ 'tenant.loyers.col_period'|trans }}</th>
                        <th>{{ 'tenant.loyers.col_amount'|trans }}</th>
                        <th>{{ 'tenant.loyers.col_due_date'|trans }}</th>
                        <th>{{ 'tenant.loyers.col_payment'|trans }}</th>
                        <th>{{ 'tenant.loyers.col_status'|trans }}</th>
                        <th>{{ 'tenant.loyers.col_receipt'|trans }}</th>
                        <th>{{ 'tenant.loyers.col_action'|trans }}</th>
                    </tr>
                </thead>
                <tbody>
                    {% set statutLabels = {
                        'payé': 'tenant.loyers.status_paid'|trans,
                        'impayé': 'tenant.loyers.status_unpaid'|trans,
                        'en_retard': 'tenant.loyers.status_overdue'|trans
                    } %}
                    {% for loyer in loyers %}
                    <tr>
                        <td>{{ loyer.colocation ? loyer.colocation.nom : '-' }}</td>
                        <td>{{ loyer.chambre ? loyer.chambre.nom : '-' }}</td>
                        <td>{{ loyer.mois }}/{{ loyer.annee }}</td>
                        <td class="fw-bold">{{ loyer.montant }}€</td>
                        <td>{{ loyer.dateEcheance|date('d/m/Y') }}</td>
                        <td>{{ loyer.datePaiement ? loyer.datePaiement|date('d/m/Y') : '-' }}</td>
                        <td>
                            <span class="badge bg-{{ loyer.statut == 'payé' ? 'success' : (loyer.statut == 'en_retard' ? 'danger' : 'warning') }}">
                                {{ statutLabels[loyer.statut] ?? loyer.statut }}
                            </span>
                        </td>
                        <td>
                            {% if loyer.quittance %}
                                <a href="{{ path('app_locataire_quittance_pdf', {id: loyer.quittance.id}) }}" class="btn btn-sm btn-outline-danger" target="_blank">
                                    <i class="bi bi-file-earmark-pdf"></i> PDF
                                </a>
                            {% else %}
                                <span class="text-muted small">{{ 'tenant.loyers.not_available'|trans }}</span>
                            {% endif %}
                        </td>
                        <td>
                            {% if loyer.statut != 'payé' %}
                            <form method="POST" action="{{ path('app_locataire_loyer_payer', {id: loyer.id}) }}" onsubmit="return confirm('{{ 'tenant.loyers.pay_confirm'|trans }}')">
                                <input type="hidden" name="_token" value="{{ csrf_token('payer_loyer_' ~ loyer.id) }}">
                                <button type="submit" class="btn btn-sm btn-success">
                                    <i class="bi bi-credit-card"></i> {{ 'tenant.loyers.pay_btn'|trans }}
                                </button>
                            </form>
                            {% else %}
                                <span class="text-success small"><i class="bi bi-check-circle"></i> {{ 'tenant.loyers.paid_label'|trans }}</span>
                            {% endif %}
                        </td>
                    </tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>
    </div>
    {% endif %}
</div>
{% endblock %}
