{% extends 'base.html.twig' %}
{% block title %}Messagerie{% endblock %}

{% block body %}
<div class="container py-5">
    <h1 class="fw-bold mb-4"><i class="bi bi-chat-dots text-primary"></i> Messagerie</h1>

    <div class="row g-4">
        <div class="col-md-4">
            <div class="card p-3">
                <h2 class="h6 fw-bold mb-3">Conversations</h2>
                {% if conversations|length == 0 %}
                    <p class="text-muted small">Aucune conversation.</p>
                {% else %}
                <div class="list-group list-group-flush">
                    {% for conv in conversations %}
                    <a href="#conv-{{ conv.user.id }}" class="list-group-item list-group-item-action px-2 py-2">
                        <div class="d-flex align-items-center gap-2">
                            {% if conv.user.photoProfil %}
                                <img src="{{ asset('uploads/profils/' ~ conv.user.photoProfil) }}" width="36" height="36" class="rounded-circle" style="object-fit:cover;" loading="lazy">
                            {% else %}
                                <div class="rounded-circle bg-secondary d-flex align-items-center justify-content-center" style="width:36px;height:36px;">
                                    <i class="bi bi-person-fill text-white"></i>
                                </div>
                            {% endif %}
                            <div class="flex-grow-1 overflow-hidden">
                                <div class="fw-bold small text-truncate">{{ conv.user.nomComplet }}</div>
                                <div class="text-muted small text-truncate">{{ conv.dernierMessage }}</div>
                            </div>
                            {% if conv.nonLus > 0 %}
                                <span class="badge bg-primary rounded-pill">{{ conv.nonLus }}</span>
                            {% endif %}
                        </div>
                    </a>
                    {% endfor %}
                </div>
                {% endif %}
            </div>
        </div>

        <div class="col-md-8">
            {% if messages is defined and messages|length > 0 %}
            <div class="card p-4">
                <div class="overflow-auto mb-3" style="max-height:400px;" id="messagesList">
                    {% for message in messages %}
                    <div class="d-flex mb-3 {{ message.expediteur.id == app.user.id ? 'justify-content-end' : '' }}">
                        <div class="card p-2 px-3 {{ message.expediteur.id == app.user.id ? 'bg-primary text-white' : 'bg-light' }}" style="max-width:70%;">
                            <p class="mb-1 small">{{ message.contenu }}</p>
                            <small class="opacity-75">{{ message.envoyeLe|date('d/m H:i') }}</small>
                        </div>
                    </div>
                    {% endfor %}
                </div>
                {{ form_start(form) }}
                <div class="input-group">
                    {{ form_widget(form.contenu, {attr: {placeholder: 'Votre message…', class: 'form-control', rows: 2}}) }}
                    <button type="submit" class="btn btn-primary"><i class="bi bi-send"></i></button>
                </div>
                {{ form_end(form) }}
            </div>
            {% else %}
            <div class="card p-5 text-center text-muted">
                <i class="bi bi-chat-dots display-3 mb-3"></i>
                <p>Sélectionnez une conversation ou démarrez-en une nouvelle.</p>
                {% if proprietaire is defined %}
                {{ form_start(form) }}
                <div class="input-group mt-3">
                    {{ form_widget(form.contenu, {attr: {placeholder: 'Message au propriétaire…', class: 'form-control'}}) }}
                    <button type="submit" class="btn btn-primary"><i class="bi bi-send"></i> Envoyer</button>
                </div>
                {{ form_end(form) }}
                {% endif %}
            </div>
            {% endif %}
        </div>
    </div>
</div>
<script>
document.addEventListener('DOMContentLoaded', () => {
    const list = document.getElementById('messagesList');
    if (list) list.scrollTop = list.scrollHeight;

    document.querySelectorAll('textarea').forEach(ta => {
        ta.addEventListener('keydown', e => {
            if (e.key === 'Enter' && !e.shiftKey) {
                e.preventDefault();
                ta.closest('form').submit();
            }
        });
    });
});
</script>
{% endblock %}
