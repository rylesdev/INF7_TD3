{% extends 'base.html.twig' %}
{% block title %}Notifications{% endblock %}

{% block body %}
<div class="container py-5">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1 class="fw-bold mb-0"><i class="bi bi-bell text-primary"></i> Notifications</h1>
        {% if notifications|length > 0 %}
        <form method="POST" action="{{ path('app_notifications_mark_read') }}" class="d-inline">
            <button type="submit" class="btn btn-outline-secondary btn-sm">
                <i class="bi bi-check-all"></i> Tout marquer comme lu
            </button>
        </form>
        {% endif %}
    </div>

    {% if notifications|length == 0 %}
        <div class="alert alert-info">Aucune notification.</div>
    {% else %}
    <div class="list-group">
        {% for notif in notifications %}
        {% set tag = notif.lien ? 'a' : 'div' %}
        <{{ tag }}{% if notif.lien %} href="{{ notif.lien }}"{% endif %} class="list-group-item list-group-item-action d-flex gap-3 py-3 text-decoration-none text-dark" style="{{ not notif.lue ? 'border-left:4px solid #2c7be5;background:#f0f6ff;' : 'border-left:4px solid transparent;' }}">
            <div class="flex-shrink-0 pt-1">
                <i class="bi bi-{{ notif.type == 'loyer' or notif.type == 'loyer_retard' ? 'cash' : (notif.type == 'nouveau_message' ? 'chat-dots' : 'bell') }} text-primary fs-5"></i>
            </div>
            <div class="flex-grow-1">
                <div class="fw-bold small mb-1">{{ notif.titre }}</div>
                <p class="mb-1 small">{{ notif.message }}</p>
                <small class="text-muted">{{ notif.creeLe|date('d/m/Y à H:i') }}</small>
            </div>
            {% if not notif.lue %}
                <span class="badge bg-primary align-self-center">Nouveau</span>
            {% endif %}
            {% if notif.lien %}
                <i class="bi bi-chevron-right text-muted align-self-center"></i>
            {% endif %}
        </{{ tag }}>
        {% endfor %}
    </div>
    {% endif %}
</div>
{% endblock %}
