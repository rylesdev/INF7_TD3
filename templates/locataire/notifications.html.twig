{% extends 'base.html.twig' %}
{% block title %}Notifications{% endblock %}

{% block body %}
<div class="container py-5">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1 class="fw-bold mb-0"><i class="bi bi-bell text-primary"></i> Notifications</h1>
        {% if notifications|length > 0 %}
        <a href="{{ path('app_notifications_mark_read') }}" class="btn btn-outline-secondary btn-sm">
            <i class="bi bi-check-all"></i> Tout marquer comme lu
        </a>
        {% endif %}
    </div>

    {% if notifications|length == 0 %}
        <div class="alert alert-info">Aucune notification.</div>
    {% else %}
    <div class="list-group">
        {% for notif in notifications %}
        <div class="list-group-item list-group-item-action d-flex gap-3 py-3 {{ not notif.lue ? 'bg-light' : '' }}">
            <div class="flex-shrink-0 pt-1">
                <i class="bi bi-{{ notif.type == 'loyer' ? 'cash' : (notif.type == 'message' ? 'chat-dots' : 'bell') }} text-primary fs-5"></i>
            </div>
            <div class="flex-grow-1">
                <p class="mb-1">{{ notif.message }}</p>
                <small class="text-muted">{{ notif.creeLe|date('d/m/Y à H:i') }}</small>
            </div>
            {% if not notif.lue %}
                <span class="badge bg-primary align-self-center">Nouveau</span>
            {% endif %}
        </div>
        {% endfor %}
    </div>
    {% endif %}
</div>
{% endblock %}
